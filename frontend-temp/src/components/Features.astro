---
import seo from "../data/seo.json";
const featuresData = seo.sections.features;
---

<section class="py-24 bg-gray-50">
  <div class="max-w-6xl mx-auto px-6">
    <!-- H2 Title -->
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">
        {featuresData.title}
      </h2>
      <p class="text-xl text-gray-600 max-w-3xl mx-auto">
        {featuresData.description}
      </p>
    </div>

    <!-- H3 Grid -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {featuresData.h3_items.map((item) => (
        <div class="bg-white p-8 rounded-xl shadow-lg hover:shadow-2xl transition duration-300 border-t-4 border-indigo-600">
          <h3 class="text-xl font-bold text-gray-900 mb-3">
            {item.heading}
          </h3>
          
          <p class="text-gray-600 mb-4 leading-relaxed">
            {item.description}
          </p>
          
          <div class="flex flex-wrap gap-2">
            {item.keywords.split(", ").map((keyword) => (
              <span class="text-xs bg-indigo-100 text-indigo-700 px-3 py-1 rounded-full font-semibold">
                {keyword}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>