---
import seo from "../data/seo.json";
const whyData = seo.sections.h2_why_salamtalk;
---

<section class="py-24 bg-gradient-to-r from-indigo-600 to-purple-600 text-white">
  <div class="max-w-6xl mx-auto px-6">
    <!-- H2 Title - Final Section -->
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-5xl font-bold mb-4">
        {whyData.title}
      </h2>
      <p class="text-xl text-white text-opacity-90 max-w-2xl mx-auto">
        {whyData.description}
      </p>
    </div>

    <!-- Stats Grid with Testimonials -->
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
      {whyData.items.map((item) => (
        <div class="bg-white bg-opacity-10 backdrop-blur rounded-xl p-8 border border-white border-opacity-20 hover:bg-opacity-20 transition">
          <div class="text-5xl font-bold mb-3">
            {item.number}
          </div>
          <h3 class="text-lg font-semibold mb-4">
            {item.label}
          </h3>
          <p class="text-sm text-white text-opacity-80 italic">
            "{item.testimonial}"
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
