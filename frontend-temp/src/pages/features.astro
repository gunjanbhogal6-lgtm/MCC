---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
---

<Layout
  title="Features"
  description="Explore advanced communication features including VoIP, encrypted messaging, call analytics, and HD video conferencing."
>
  <Navbar />

  <section class="py-24 text-center bg-gradient-to-r from-indigo-50 to-purple-50">
