{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CSV Input Schema",
  "description": "Expected columns in input CSV files",
  "type": "object",
  "required": ["columns"],
  "properties": {
    "columns": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "type"],
        "properties": {
          "name": { "type": "string" },
          "type": { 
            "type": "string", 
            "enum": ["string", "integer", "float", "array"] 
          },
          "required": { "type": "boolean", "default": false },
          "description": { "type": "string" }
        }
      }
    }
  },
  "default": {
    "columns": [
      { "name": "Keyword", "type": "string", "required": true, "description": "Target keyword phrase" },
      { "name": "Search Volume", "type": "integer", "required": false, "description": "Monthly search volume" },
      { "name": "Keyword Difficulty", "type": "integer", "required": false, "description": "Difficulty score 0-100" },
      { "name": "CPC", "type": "float", "required": false, "description": "Cost per click in USD" },
      { "name": "Position", "type": "integer", "required": false, "description": "Current ranking position" },
      { "name": "URL", "type": "string", "required": false, "description": "Ranking URL" },
      { "name": "Trends", "type": "string", "required": false, "description": "Trend data" },
      { "name": "Keyword Intents", "type": "array", "required": false, "description": "Search intent types" },
      { "name": "SERP Features by Keyword", "type": "array", "required": false, "description": "SERP feature types" }
    ]
  }
}
