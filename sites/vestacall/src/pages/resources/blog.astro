---
import MainLayout from '../../layouts/MainLayout.astro';
---

<MainLayout title="Blog" description="Insights and industry news from VestaCall." pathname="/resources/blog">
  <section class="relative pt-28 pb-16 overflow-hidden bg-gradient-to-br from-gray-50 via-white to-vesta-purple/5">
    <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-vesta-purple/10 rounded-full blur-[150px] pointer-events-none"></div>
    <div class="container mx-auto px-6 max-w-6xl relative z-10">
      <div class="text-center">
        <div class="inline-flex items-center gap-2 bg-vesta-purple/10 border border-vesta-purple/20 rounded-full px-4 py-2 mb-6">
          <svg class="w-4 h-4 text-vesta-purple" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" /></svg>
          <span class="text-sm font-bold text-vesta-purple">Resources</span>
        </div>
        <h1 class="text-4xl md:text-6xl font-black text-gray-900 tracking-tight leading-tight mb-6">
          Blog & <span class="text-transparent bg-clip-text bg-gradient-to-r from-vesta-purple to-fuchsia-600">Insights</span>
        </h1>
        <p class="text-xl text-gray-600 max-w-2xl mx-auto leading-relaxed font-medium">
          Deep-dives into carrier quality, billing optimization, and compliance from our engineering and leadership teams.
        </p>
      </div>
    </div>
  </section>

  <section class="py-24 bg-white border-t border-gray-100">
    <div class="container mx-auto px-6 max-w-6xl">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {[
          { tag: "Carrier Infrastructure", tagColor: "text-vesta-purple", title: "Understanding Global Connectivity: Why Carrier Quality Matters", desc: "Discover how bypassing public congestion impacts ASR/PDD metrics.", author: "Engineering Staff" },
          { tag: "Cost Optimization", tagColor: "text-fuchsia-500", title: "Stop Paying for Seconds You Don't Use: The Business Case for 1/1 Billing", desc: "How precise billing increments save massive overhead money.", author: "Billing Team" },
          { tag: "Security & Compliance", tagColor: "text-blue-500", title: "Combatting Spoofing: How STIR/SHAKEN Protects Your Brand", desc: "The importance of Caller ID authentication and legal traffic routing.", author: "Compliance Dept." },
          { tag: "Analytics & ROI", tagColor: "text-emerald-500", title: "The Hidden Metrics of Success: What ASR and ACD Really Mean", desc: "How to measure the health of your communications operations.", author: "VestaCall Exec" },
          { tag: "Product Updates", tagColor: "text-amber-500", title: "New Feature: AI-Powered Sentiment Analysis", desc: "Real-time emotional tone analysis for better customer interactions.", author: "Product Team" },
          { tag: "Industry News", tagColor: "text-rose-500", title: "The Future of Cloud Communications in 2025", desc: "Trends and predictions from our leadership team.", author: "VestaCall Team" },
        ].map((article) => (
          <a href="/resources/blog" class="block group">
            <div class="bg-white rounded-3xl border border-gray-100 p-8 h-full hover:border-vesta-purple/30 hover:shadow-xl transition-all duration-300">
              <span class={`text-xs font-bold uppercase tracking-wider mb-4 block ${article.tagColor}`}>
                {article.tag}
              </span>
              <h3 class="text-xl font-bold text-gray-900 mb-4 group-hover:text-vesta-purple transition-colors">
                {article.title}
              </h3>
              <p class="text-gray-600 font-medium mb-6 leading-relaxed">
                {article.desc}
              </p>
              <div class="flex items-center justify-between text-sm text-gray-500 font-bold border-t border-gray-100 pt-6">
                <span class="flex items-center gap-2">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>
                  {article.author}
                </span>
                <span class="flex items-center gap-2 group-hover:text-vesta-purple transition-colors">
                  Read <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
                </span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</MainLayout>