---
import MainLayout from '../../layouts/MainLayout.astro';
---

<MainLayout title="Case Studies" description="Success stories from VestaCall customers." pathname="/resources/case-studies">
  <section class="relative pt-28 pb-16 overflow-hidden bg-gradient-to-br from-gray-50 via-white to-vesta-purple/5">
    <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-vesta-purple/10 rounded-full blur-[150px] pointer-events-none"></div>
    <div class="container mx-auto px-6 max-w-6xl relative z-10">
      <div class="text-center">
        <div class="inline-flex items-center gap-2 bg-vesta-purple/10 border border-vesta-purple/20 rounded-full px-4 py-2 mb-6">
          <svg class="w-4 h-4 text-vesta-purple" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
          <span class="text-sm font-bold text-vesta-purple">Resources</span>
        </div>
        <h1 class="text-4xl md:text-6xl font-black text-gray-900 tracking-tight leading-tight mb-6">
          Case <span class="text-transparent bg-clip-text bg-gradient-to-r from-vesta-purple to-fuchsia-600">Studies</span>
        </h1>
        <p class="text-xl text-gray-600 max-w-2xl mx-auto leading-relaxed font-medium">
          See how leading businesses use VestaCall to transform their customer communications.
        </p>
      </div>
    </div>
  </section>

  <section class="py-24 bg-white border-t border-gray-100">
    <div class="container mx-auto px-6 max-w-6xl">
      <div class="grid md:grid-cols-2 gap-8">
        {[
          { company: "Nexus Enterprises", metric: "+40%", metricLabel: "More Interactions", title: "Global Support Transformation", desc: "How Nexus Enterprises transformed their support architecture and now handles 40% more customer interactions with the same team." },
          { company: "Lumina Data", metric: "99.99%", metricLabel: "Uptime", title: "Enterprise Voice Clarity", desc: "How Lumina Data achieved exceptional voice clarity and identified critical churn risks with AI-powered sentiment analysis." },
          { company: "FinShift", metric: "< 2 hrs", metricLabel: "Deployment", title: "Rapid Number Porting", desc: "How FinShift ported 500 numbers in under two hours and eliminated legacy hardware complexity." },
          { company: "GlobalTech", metric: "300%", metricLabel: "ROI", title: "Sales Acceleration", desc: "How GlobalTech tripled their connection rates with predictive dialers and local presence calling." },
        ].map((study) => (
          <a href="/resources/case-studies" class="block group">
            <div class="bg-white rounded-3xl border border-gray-100 p-8 h-full hover:border-vesta-purple/30 hover:shadow-xl transition-all duration-300">
              <div class="bg-vesta-purple rounded-xl p-4 inline-block mb-6">
                <p class="text-3xl font-black text-white">{study.metric}</p>
                <p class="text-xs font-bold text-white/80 uppercase tracking-widest mt-1">{study.metricLabel}</p>
              </div>
              <h3 class="text-xl font-bold text-gray-900 mb-2 group-hover:text-vesta-purple transition-colors">
                {study.title}
              </h3>
              <p class="text-gray-500 font-bold text-sm mb-4">{study.company}</p>
              <p class="text-gray-600 font-medium leading-relaxed">
                {study.desc}
              </p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</MainLayout>