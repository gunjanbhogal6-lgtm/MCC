---
import MainLayout from '../layouts/MainLayout.astro';

const title = "Page Not Found | VestaCall";
const description = "Sorry, the page you're looking for doesn't exist. Return to our homepage or contact support.";
---

<MainLayout 
  title={title} 
  description={description} 
  pathname="/404"
  isDark={true}
>
  <div class="min-h-screen flex items-center justify-center bg-gradient-to-br from-vesta-dark to-purple-900/20 px-4 sm:px-6 lg:px-8">
    <div class="max-w-md w-full space-y-8 text-center">
      <div>
        <h1 class="text-9xl font-extrabold text-white tracking-tight">
          404
        </h1>
        <h2 class="mt-4 text-3xl font-bold text-white">
          Page Not Found
        </h2>
        <p class="mt-4 text-lg text-vesta-light">
          Sorry, the page you're looking for doesn't exist or has been moved.
        </p>
      </div>
      
      <div class="mt-8 space-y-4">
        <a
          href="/"
          class="w-full flex justify-center py-3 px-4 border border-transparent rounded-full shadow-sm text-base font-medium text-white bg-vesta-purple hover:bg-[#5a24b5] focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-vesta-purple transition-all"
        >
          Return to Homepage
        </a>
        
        <a
          href="/contact"
          class="w-full flex justify-center py-3 px-4 border border-gray-300 rounded-full shadow-sm text-base font-medium text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-vesta-purple transition-all"
        >
          Contact Support
        </a>
      </div>
      
      <div class="mt-12">
        <h3 class="text-lg font-medium text-white">Popular Pages</h3>
        <ul class="mt-4 space-y-2">
          <li>
            <a href="/cloud-pbx" class="text-vesta-light hover:text-white transition-colors">
              Cloud PBX
            </a>
          </li>
          <li>
            <a href="/sip-trunking" class="text-vesta-light hover:text-white transition-colors">
              SIP Trunking
            </a>
          </li>
          <li>
            <a href="/conversational-ai" class="text-vesta-light hover:text-white transition-colors">
              Conversational AI
            </a>
          </li>
          <li>
            <a href="/pricing" class="text-vesta-light hover:text-white transition-colors">
              Pricing
            </a>
          </li>
        </ul>
      </div>
    </div>
  </div>
</MainLayout>