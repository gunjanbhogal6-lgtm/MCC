---
import MainLayout from '../../layouts/MainLayout.astro';
---

<MainLayout title="Security & Compliance" description="How we protect your data at VestaCall." pathname="/company/security">
  <section class="relative pt-28 pb-16 overflow-hidden bg-gradient-to-br from-gray-50 via-white to-vesta-purple/5">
    <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-vesta-purple/10 rounded-full blur-[150px] pointer-events-none"></div>
    <div class="container mx-auto px-6 max-w-6xl relative z-10">
      <div class="text-center">
        <div class="inline-flex items-center gap-2 bg-vesta-purple/10 border border-vesta-purple/20 rounded-full px-4 py-2 mb-6">
          <svg class="w-4 h-4 text-vesta-purple" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.948 11.948 0 0112 2.944a11.948 11.948 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
          <span class="text-sm font-bold text-vesta-purple">Company</span>
        </div>
        <h1 class="text-4xl md:text-6xl font-black text-gray-900 tracking-tight leading-tight mb-6">
          Security & <span class="text-transparent bg-clip-text bg-gradient-to-r from-vesta-purple to-fuchsia-600">Compliance</span>
        </h1>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto leading-relaxed font-medium">
          Enterprise-grade security built into everything we do. Your data is protected by industry-leading security measures.
        </p>
      </div>
    </div>
  </section>

  <section class="py-24 bg-white border-t border-gray-100">
    <div class="container mx-auto px-6 max-w-6xl">
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 mb-16">
        {[
          { title: "SOC 2 Type II", desc: "Audited and certified for security, availability, and confidentiality." },
          { title: "GDPR", desc: "Full compliance with European data protection regulations." },
          { title: "HIPAA", desc: "Healthcare-compliant infrastructure for PHI protection." },
          { title: "PCI DSS", desc: "Secure payment processing compliance." },
        ].map((cert) => (
          <div class="bg-gray-50 rounded-2xl p-6 text-center border border-gray-100">
            <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-vesta-purple to-fuchsia-600 flex items-center justify-center mb-4 mx-auto shadow-lg shadow-vesta-purple/20">
              <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            </div>
            <h3 class="text-lg font-bold text-gray-900 mb-2">{cert.title}</h3>
            <p class="text-gray-600 font-medium text-sm">{cert.desc}</p>
          </div>
        ))}
      </div>

      <h2 class="text-2xl font-black text-gray-900 mb-8">Security Features</h2>
      <div class="grid md:grid-cols-2 gap-6">
        {[
          { title: "End-to-End Encryption", desc: "All calls and data encrypted in transit and at rest using AES-256." },
          { title: "Two-Factor Authentication", desc: "Mandatory 2FA for all user accounts with support for TOTP and hardware keys." },
          { title: "Role-Based Access Control", desc: "Granular permissions and access controls for enterprise security." },
          { title: "Audit Logging", desc: "Comprehensive audit trails for all system access and changes." },
          { title: "Data Residency", desc: "Choose where your data is stored for regional compliance requirements." },
          { title: "Penetration Testing", desc: "Regular third-party security assessments and penetration tests." },
        ].map((feature) => (
          <div class="flex items-start gap-4 bg-gray-50 rounded-2xl p-5 border border-gray-100">
            <svg class="w-6 h-6 text-vesta-purple flex-shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            <div>
              <h3 class="font-bold text-gray-900 mb-1">{feature.title}</h3>
              <p class="text-gray-600 font-medium text-sm">{feature.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</MainLayout>