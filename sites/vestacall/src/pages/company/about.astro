---
import MainLayout from '../../layouts/MainLayout.astro';
---

<MainLayout title="About VestaCall" description="Our story and values - Connecting customers worldwide with AI-powered cloud communication." pathname="/company/about">
  <section class="relative pt-28 pb-16 overflow-hidden bg-gradient-to-br from-gray-50 via-white to-vesta-purple/5">
    <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-vesta-purple/10 rounded-full blur-[150px] pointer-events-none"></div>
    <div class="container mx-auto px-6 max-w-6xl relative z-10">
      <div class="text-center">
        <div class="inline-flex items-center gap-2 bg-vesta-purple/10 border border-vesta-purple/20 rounded-full px-4 py-2 mb-6">
          <svg class="w-4 h-4 text-vesta-purple" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          <span class="text-sm font-bold text-vesta-purple">Company</span>
        </div>
        <h1 class="text-4xl md:text-6xl font-black text-gray-900 tracking-tight leading-tight mb-6">
          About <span class="text-transparent bg-clip-text bg-gradient-to-r from-vesta-purple to-fuchsia-600">VestaCall</span>
        </h1>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto leading-relaxed font-medium">
          We're on a mission to democratize enterprise-grade cloud communications. Every business, regardless of size, deserves access to the same tools that power the world's largest contact centers.
        </p>
      </div>
    </div>
  </section>

  <section class="py-24 bg-white border-t border-gray-100">
    <div class="container mx-auto px-6 max-w-6xl">
      <div class="grid md:grid-cols-2 gap-16 items-center">
        <div>
          <h2 class="text-3xl font-black text-gray-900 mb-6">Our Story</h2>
          <p class="text-gray-600 font-medium leading-relaxed mb-4">
            VestaCall was founded in 2020 by a team of telecommunications veterans who believed that modern businesses deserved better than legacy phone systems. We saw companies struggling with outdated hardware, complex integrations, and astronomical costs.
          </p>
          <p class="text-gray-600 font-medium leading-relaxed mb-4">
            Today, we serve thousands of businesses across the globe—from fast-growing startups to Fortune 500 enterprises. Our platform handles millions of calls every day, connecting customers with the businesses they love.
          </p>
          <p class="text-gray-600 font-medium leading-relaxed">
            We're not just building software; we're building the infrastructure for the future of business communication.
          </p>
        </div>
        <div class="grid grid-cols-2 gap-6">
          {[
            { value: "50K+", label: "Active Users" },
            { value: "100+", label: "Countries" },
            { value: "1M+", label: "Calls Daily" },
            { value: "99.999%", label: "Uptime" },
          ].map((stat) => (
            <div class="bg-gray-50 rounded-2xl p-6 text-center">
              <p class="text-3xl font-black text-vesta-purple mb-2">{stat.value}</p>
              <p class="text-gray-500 font-bold text-sm uppercase tracking-wider">{stat.label}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="py-24 bg-gray-50 border-t border-gray-200">
    <div class="container mx-auto px-6 max-w-6xl">
      <h2 class="text-3xl font-black text-gray-900 mb-12 text-center">Our Values</h2>
      <div class="grid md:grid-cols-3 gap-8">
        {[
          { title: "Customer First", desc: "Every decision we make starts with the customer. We build what they need, not what we think is cool.", icon: "users" },
          { title: "Radical Transparency", desc: "No hidden fees, no surprise charges. We believe in honest, straightforward business practices.", icon: "shield" },
          { title: "Continuous Innovation", desc: "We ship fast and iterate faster. The best communications platform is the one that keeps getting better.", icon: "zap" },
        ].map((value) => (
          <div class="bg-white rounded-3xl p-8 border border-gray-100">
            <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-vesta-purple to-fuchsia-600 flex items-center justify-center mb-6 shadow-lg shadow-vesta-purple/20">
              <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                {value.icon === "users" && <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />}
                {value.icon === "shield" && <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.948 11.948 0 0112 2.944a11.948 11.948 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />}
                {value.icon === "zap" && <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />}
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-3">{value.title}</h3>
            <p class="text-gray-600 font-medium leading-relaxed">{value.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</MainLayout>