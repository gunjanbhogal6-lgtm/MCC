---
import MainLayout from '../layouts/MainLayout.astro';
import productsData from '../data/products.json';
import solutionsData from '../data/solutions.json';

const title = "Sitemap | VestaCall";
const description = "Complete sitemap of all pages on VestaCall - AI-powered cloud contact center and UCaaS provider.";

// Get all product pages
const productPages = productsData.items.map(product => ({
  title: `${product.name} - ${product.hero.subtitle}`,
  url: product.url,
  category: "Products"
}));

// Get all solution pages
const solutionPages = solutionsData.items.map(solution => ({
  title: solution.name,
  url: solution.url,
  category: "Solutions"
}));

// Static pages
const staticPages = [
  { title: "Home", url: "/", category: "Main" },
  { title: "Pricing", url: "/pricing", category: "Main" },
  { title: "Contact", url: "/contact", category: "Main" },
  { title: "Live Analytics", url: "/live-analytics", category: "Features" },
  { title: "Conversational AI", url: "/conversational-ai", category: "Products" },
  { title: "Cloud PBX", url: "/cloud-pbx", category: "Products" },
  { title: "SIP Trunking", url: "/sip-trunking", category: "Products" },
];

// Combine all pages
const allPages = [...staticPages, ...productPages, ...solutionPages];

// Group by category
const pagesByCategory: Record<string, Array<{title: string, url: string, category: string}>> = allPages.reduce((acc: Record<string, Array<{title: string, url: string, category: string}>>, page) => {
  if (!acc[page.category]) {
      acc[page.category] = [];
  }
  acc[page.category].push(page);
  return acc;
}, {});
---

<MainLayout 
  title={title} 
  description={description} 
  pathname="/sitemap"
  breadcrumbs={[
    { name: "Home", url: "/" },
    { name: "Sitemap", url: "/sitemap" }
  ]}
>
  <section class="py-24 bg-white">
    <div class="container mx-auto px-6 max-w-6xl">
      <div class="text-center mb-16">
        <h1 class="text-4xl md:text-5xl font-black text-gray-900 tracking-tight mb-4">
          Sitemap
        </h1>
        <p class="text-gray-600 text-lg font-medium max-w-2xl mx-auto">
          Complete list of all pages on VestaCall
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {Object.entries(pagesByCategory).map(([category, pages]) => (
          <div class="bg-gray-50 rounded-2xl p-6 border border-gray-100">
            <h2 class="text-xl font-bold text-gray-900 mb-4 pb-2 border-b border-gray-200">
              {category}
            </h2>
            <ul class="space-y-2">
              {pages.map((page: any) => (
                <li>
                  <a href={page.url} class="text-gray-600 hover:text-vesta-purple transition-colors font-medium">
                    {page.title}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>
</MainLayout>