---
interface Props {
  product: {
    id: string;
    name: string;
    shortDescription: string;
    description: string;
    url: string;
    badge: string;
    icon: string;
    features: string[];
    pricing: string;
    keywords: string[];
    hero: {
      h1: string;
      subtitle: string;
      description: string;
    };
    benefits: string[];
    featureList: Array<{ title: string; description: string; icon: string }>;
  };
}

const { product } = Astro.props;

<script is:inline type="application/ld+json">
  {JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Product",
    "name": product.name,
    "description": product.shortDescription,
    "url": `https://vestacall.com${product.url}`,
    "category": product.badge,
    "offers": {
      "@type": "Offer",
      "priceCurrency": "USD",
      "price": product.pricing.includes('$') ? product.pricing.replace(/[^0-9.]/g, '') : "0",
      "availability": "https://schema.org/InStock"
    },
    "featureList": product.features,
    "keywords": product.keywords.join(', '),
    "brand": {
      "@type": "Brand",
      "name": "VestaCall"
    },
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "4.8",
      "reviewCount": "2500"
    }
  })}
</script>