---
---

<section class="py-32 bg-[#0b0416] border-t border-b border-vesta-purple/20 relative overflow-hidden flex flex-col items-center justify-center">
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[300px] bg-vesta-purple/20 blur-[130px] rounded-full pointer-events-none"></div>

  <p class="text-white/60 text-xs font-semibold tracking-[0.2em] uppercase mb-6 relative z-10 text-center">
    Trusted by Innovative Teams Worldwide
  </p>

  <div class="w-full relative flex overflow-x-hidden group">
    <div class="absolute top-0 left-0 w-24 md:w-48 h-full bg-gradient-to-r from-[#0b0416] to-transparent z-10 pointer-events-none"></div>
    <div class="absolute top-0 right-0 w-24 md:w-48 h-full bg-gradient-to-l from-[#0b0416] to-transparent z-10 pointer-events-none"></div>

    <div class="animate-marquee flex gap-20 items-center whitespace-nowrap">
      <div class="flex items-center gap-3 text-white/50 hover:text-white opacity-80 hover:opacity-100 transition-all duration-300 cursor-pointer">
        <svg class="w-7 h-7 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" /></svg>
        <span class="text-xl font-bold font-sans tracking-tight">AcmeCorp</span>
      </div>
      <div class="flex items-center gap-3 text-white/50 hover:text-white opacity-80 hover:opacity-100 transition-all duration-300 cursor-pointer">
        <svg class="w-7 h-7 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
        <span class="text-xl font-black font-serif italic">Globalnet</span>
      </div>
      <div class="flex items-center gap-3 text-white/50 hover:text-white opacity-80 hover:opacity-100 transition-all duration-300 cursor-pointer">
        <svg class="w-6 h-6 text-rose-400 fill-current" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" /></svg>
        <span class="text-lg font-bold font-mono tracking-widest uppercase">Vertex</span>
      </div>
      <div class="flex items-center gap-3 text-white/50 hover:text-white opacity-80 hover:opacity-100 transition-all duration-300 cursor-pointer">
        <svg class="w-8 h-8 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z" /></svg>
        <span class="text-xl font-extrabold tracking-tight">Nimbus</span>
      </div>
      <div class="flex items-center gap-3 text-white/50 hover:text-white opacity-80 hover:opacity-100 transition-all duration-300 cursor-pointer">
        <svg class="w-7 h-7 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" /></svg>
        <span class="text-lg font-bold uppercase tracking-[0.15em]">NovaCore</span>
      </div>
      <div class="flex items-center gap-3 text-white/50 hover:text-white opacity-80 hover:opacity-100 transition-all duration-300 cursor-pointer">
        <svg class="w-7 h-7 text-[#b854f5]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" /></svg>
        <span class="text-xl font-semibold tracking-wide">Synergy</span>
      </div>
      
      <div class="flex items-center gap-3 text-white/50 hover:text-white opacity-80 hover:opacity-100 transition-all duration-300 cursor-pointer">
        <svg class="w-7 h-7 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" /></svg>
        <span class="text-xl font-bold font-sans tracking-tight">AcmeCorp</span>
      </div>
      <div class="flex items-center gap-3 text-white/50 hover:text-white opacity-80 hover:opacity-100 transition-all duration-300 cursor-pointer">
        <svg class="w-7 h-7 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
        <span class="text-xl font-black font-serif italic">Globalnet</span>
      </div>
      <div class="flex items-center gap-3 text-white/50 hover:text-white opacity-80 hover:opacity-100 transition-all duration-300 cursor-pointer">
        <svg class="w-6 h-6 text-rose-400 fill-current" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" /></svg>
        <span class="text-lg font-bold font-mono tracking-widest uppercase">Vertex</span>
      </div>
      <div class="flex items-center gap-3 text-white/50 hover:text-white opacity-80 hover:opacity-100 transition-all duration-300 cursor-pointer">
        <svg class="w-8 h-8 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z" /></svg>
        <span class="text-xl font-extrabold tracking-tight">Nimbus</span>
      </div>
      <div class="flex items-center gap-3 text-white/50 hover:text-white opacity-80 hover:opacity-100 transition-all duration-300 cursor-pointer">
        <svg class="w-7 h-7 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" /></svg>
        <span class="text-lg font-bold uppercase tracking-[0.15em]">NovaCore</span>
      </div>
      <div class="flex items-center gap-3 text-white/50 hover:text-white opacity-80 hover:opacity-100 transition-all duration-300 cursor-pointer">
        <svg class="w-7 h-7 text-[#b854f5]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" /></svg>
        <span class="text-xl font-semibold tracking-wide">Synergy</span>
      </div>
    </div>
  </div>
</section>

<style>
  .animate-marquee {
    animation: marquee 120s linear infinite;
  }
  .animate-marquee:hover {
    animation-play-state: paused;
  }
  @keyframes marquee {
    0% { transform: translateX(0%); }
    100% { transform: translateX(-50%); }
  }
</style>
