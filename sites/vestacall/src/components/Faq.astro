---
import schemaData from '../data/schemas.json';

const faqData = {
  title: "Frequently Asked Questions",
  description: "Everything you need to know about the product and billing.",
  items: [
    {
      question: "How long does it take to get started?",
      answer: "VestaCall is designed for rapid deployment. Our cloud-native architecture allows most teams to go live in under 24 hours with full SIP integration and AI receptionist setup."
    },
    {
      question: "Do you integrate with CRM tools like Salesforce or Hubspot?",
      answer: "Yes, VestaCall offers native bi-directional integrations with Salesforce, HubSpot, Zendesk, and 50+ other leading CRM and helpdesk tools to keep your customer data perfectly synced."
    },
    {
      question: "Is there a limit to how many concurrent calls I can have?",
      answer: "Our global cloud infrastructure is elastically scalable. Whether you need 5 or 5,000 concurrent channels, VestaCall handles your peak-hour volume with zero latency and 99.999% reliability."
    },
    {
      question: "Does VestaCall support local numbers in my country?",
      answer: "We provide local, national, and toll-free numbers in over 120 countries. Our global Tier-1 network ensuring your business maintains a local presence anywhere in the world."
    },
    {
      question: "Is my customers' call data secure and compliant?",
      answer: "Security is our core pillar. VestaCall is SOC-2 Type II certified and fully compliant with HIPAA, GDPR, and PCI-DSS, featuring end-to-end encryption for all voice and data transmissions."
    }
  ]
};
---

<section class="py-24 bg-[#fbfbfe] relative overflow-hidden">
  {/* Soft background glow */}
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-[600px] bg-purple-100 opacity-20 blur-[150px] pointer-events-none"></div>

  <div class="container mx-auto px-6 max-w-4xl relative z-10">
    <div class="text-center mb-20">
      <h2 class="text-3xl sm:text-5xl md:text-6xl font-black mb-6 text-slate-900 tracking-tight">
        Frequently Asked <span class="bg-gradient-to-r from-purple-600 to-fuchsia-500 bg-clip-text text-transparent">Questions</span>
      </h2>
      <p class="text-slate-500 text-lg font-medium">{faqData.description}</p>
    </div>

    <div class="space-y-5" id="faq-container">
      {faqData.items.map((faq, index) => (
        <div class={`faq-item group bg-white border border-slate-100 rounded-[28px] overflow-hidden transition-all duration-300 hover:border-purple-200 hover:shadow-[0_15px_30px_rgba(124,58,237,0.05)] ${index >= 3 ? 'hidden sm:block' : ''}`} data-index={index}>
          <button
            class="w-full px-6 sm:px-10 py-8 flex items-center justify-between text-left focus:outline-none"
            onclick="toggleFaq(this)"
          >
            <span class="text-xl font-bold text-slate-800 group-hover:text-purple-600 transition-colors faq-question leading-tight">{faq.question}</span>
            <span class="flex-shrink-0 ml-4 w-10 h-10 rounded-full border border-slate-100 flex items-center justify-center text-slate-300 group-hover:bg-purple-50 group-hover:text-purple-600 group-hover:border-purple-100 transition-all faq-icon">
              <svg class="w-5 h-5 transition-transform duration-300 plus-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m6-6H6" /></svg>
            </span>
          </button>
          <div class="faq-answer hidden bg-white">
            <div class="px-10 pb-10 pt-2 text-slate-500 text-lg font-medium leading-relaxed max-w-3xl">
              {faq.answer}
            </div>
          </div>
        </div>
      ))}
    </div>

    <div class="mt-8 text-center sm:hidden">
      <button class="px-8 py-3 rounded-full border border-purple-200 text-purple-600 font-bold hover:bg-purple-50 transition-all" onclick="document.querySelectorAll('.faq-item.hidden').forEach(el => el.classList.remove('hidden')); this.parentElement.remove();">
        Show More Questions
      </button>
    </div>
  </div>
</section>

<script is:inline type="application/ld+json" set:html={JSON.stringify(schemaData.faq)} />

<script is:inline>
  function toggleFaq(button) {
    const item = button.closest('.faq-item');
    const answer = item.querySelector('.faq-answer');
    const question = item.querySelector('.faq-question');
    const iconContainer = item.querySelector('.faq-icon');
    const plusIcon = item.querySelector('.plus-icon');
    
    const isOpen = !answer.classList.contains('hidden');
    
    // Close all others
    document.querySelectorAll('.faq-item').forEach(otherItem => {
      if (otherItem !== item) {
        otherItem.querySelector('.faq-answer').classList.add('hidden');
        otherItem.querySelector('.faq-question').classList.remove('text-purple-600');
        otherItem.querySelector('.faq-question').classList.add('text-slate-800');
        otherItem.querySelector('.faq-icon').classList.remove('bg-purple-50', 'text-purple-600', 'border-purple-100');
        otherItem.querySelector('.faq-icon').classList.add('bg-transparent', 'text-slate-300', 'border-slate-100');
        otherItem.querySelector('.plus-icon').style.transform = 'rotate(0deg)';
        otherItem.classList.remove('border-purple-200', 'shadow-[0_15px_30px_rgba(124,58,237,0.1)]');
      }
    });
    
    if (isOpen) {
      answer.classList.add('hidden');
      question.classList.remove('text-purple-600');
      question.classList.add('text-slate-800');
      iconContainer.classList.remove('bg-purple-50', 'text-purple-600', 'border-purple-100');
      iconContainer.classList.add('bg-transparent', 'text-slate-300', 'border-slate-100');
      plusIcon.style.transform = 'rotate(0deg)';
      item.classList.remove('border-purple-200', 'shadow-[0_15px_30px_rgba(124,58,237,0.1)]');
    } else {
      answer.classList.remove('hidden');
      question.classList.add('text-purple-600');
      question.classList.remove('text-slate-800');
      iconContainer.classList.add('bg-purple-50', 'text-purple-600', 'border-purple-100');
      iconContainer.classList.remove('bg-transparent', 'text-slate-300', 'border-slate-100');
      plusIcon.style.transform = 'rotate(45deg)';
      item.classList.add('border-purple-200', 'shadow-[0_15px_30px_rgba(124,58,237,0.1)]');
    }
  }
</script>

