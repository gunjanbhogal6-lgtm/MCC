---
import MainLayout from "../layouts/MainLayout.astro";
import productsData from "../data/products.json";

interface Props {
  productId: string;
}

const { productId } = Astro.props;
const product = productsData.items.find((p) => p.id === productId);

// Redirect to 404 if product not found
if (!product) {
  Astro.redirect("/404");
  // Exit early to prevent rendering
  throw new Error("Product not found");
}

const iconMap: Record<string, string> = {
  phone:
    '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />',
  globe:
    '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />',
  shield:
    '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.948 11.948 0 0112 2.944a11.948 11.948 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />',
  zap: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />',
  users:
    '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />',
  server:
    '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01" />',
  activity:
    '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />',
  network:
    '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.111 16.404a5.5 5.5 0 017.778 0M12 20h.01m-7.08-7.071c3.904-3.905 10.236-3.905 14.141 0M1.394 9.393c5.857-5.857 15.355-5.857 21.213 0" />',
  bot: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />',
  message:
    '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />',
  brain:
    '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />',
  calendar:
    '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />',
  headset:
    '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 18v-6a9 9 0 0118 0v6" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 19a2 2 0 01-2 2h-1a2 2 0 01-2-2v-3a2 2 0 012-2h3zM3 19a2 2 0 002 2h1a2 2 0 002-2v-3a2 2 0 00-2-2H3z" />',
  chart:
    '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3v18h18" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16l4-4 4 4 5-5" />',
};

const pbxSteps = [
  { icon: 'M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z', label: 'PSTN', bg: 'bg-gray-100', text: 'text-gray-600' },
  { icon: 'M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z', label: 'SBC', bg: 'bg-yellow-50', text: 'text-yellow-600' },
  { icon: 'M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01', label: 'PBX', bg: 'bg-purple-50', text: 'text-purple-600' },
  { icon: 'M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z', label: 'AGENT', bg: 'bg-gray-50', text: 'text-gray-400' }
];

const analyticsKpis = [
  { label: 'ACTIVE CALLS', value: '142', up: true },
  { label: 'AVG WAIT', value: '0:08', down: true },
  { label: 'CSAT', value: '4.9', up: true }
];
---

<MainLayout
  title={`${product.name} - ${product.hero?.subtitle || product.badge} | VestaCall`}
  description={product.shortDescription}
  pathname={product.url}
  keywords={product.keywords || []}
  breadcrumbs={[
    { name: "Home", url: "/" },
    { name: "Products", url: "/products" },
    { name: product.name, url: product.url },
  ]}
  productSchema={{
    "@context": "https://schema.org",
    "@type": "Product",
    name: product.name,
    description: product.description,
    url: `https://vestacall.com${product.url}`,
    category: product.badge,
    offers: {
      "@type": "Offer",
      priceCurrency: "USD",
      price:
        product.pricing &&
        typeof product.pricing === "string" &&
        product.pricing.includes("$")
          ? product.pricing.replace(/[^0-9.]/g, "")
          : "0",
      availability: "https://schema.org/InStock",
      priceSpecification: {
        price:
          product.pricing &&
          typeof product.pricing === "string" &&
          product.pricing.includes("$")
            ? product.pricing.replace(/[^0-9.]/g, "")
            : "0",
        priceCurrency: "USD",
      },
    },
    featureList: product.features || [],
    keywords: product.keywords?.join(", ") || "",
    brand: {
      "@type": "Brand",
      name: "VestaCall",
    },
    aggregateRating: {
      "@type": "AggregateRating",
      ratingValue: "4.8",
      reviewCount: "2500",
    },
  }}
>
  {
    product.heroPbx ? (
      <section class="relative pt-12 pb-16 lg:pt-16 lg:pb-20 overflow-hidden bg-gradient-to-br from-gray-50 via-white to-gray-200">
        <div class="absolute inset-0 bg-[url('/noise.png')] opacity-[0.03] mix-blend-overlay pointer-events-none"></div>
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-vesta-purple/10 rounded-full blur-[100px] pointer-events-none"></div>
        
        <div class="container mx-auto px-6 max-w-7xl relative z-10">
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
            {/* Left Column: Text */}
            <div class="max-w-xl">
              <div class="inline-flex items-center gap-2 bg-vesta-purple/10 border border-vesta-purple/20 rounded-full px-4 py-1.5 mb-6">
                <svg class="w-4 h-4 text-vesta-purple" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
                <span class="text-sm font-bold text-vesta-purple">{product.heroPbx.badge}</span>
              </div>
              <h1 class="text-4xl sm:text-5xl lg:text-[4.5rem] font-black text-gray-900 tracking-tight leading-[1.05] mb-6">
                {product.heroPbx.h1}<br/>
                <span class="text-vesta-purple">{product.heroPbx.h1Highlight}</span>
              </h1>
              <p class="text-xl lg:text-2xl text-gray-600 leading-relaxed font-medium mb-10 max-w-[500px] hidden sm:block">
                {product.heroPbx.description}
              </p>
              <p class="text-lg text-gray-600 leading-relaxed font-medium mb-8 sm:hidden">
                {product.heroPbx.description.split('. ')[0]}.
              </p>
              <div class="flex flex-col sm:flex-row gap-4">
                <a href="/contact" class="inline-flex items-center justify-center px-8 py-4 rounded-full bg-vesta-purple text-white font-bold text-lg hover:bg-[#5a24b5] transition-all shadow-lg hover:-translate-y-1">
                  {product.heroPbx.primaryButton}
                </a>
                <a href="/contact" class="inline-flex items-center justify-center px-8 py-4 rounded-full bg-white text-gray-900 font-bold text-lg hover:bg-gray-50 transition-all shadow-sm border border-gray-200 hover:-translate-y-1">
                  {product.heroPbx.secondaryButton}
                </a>
              </div>
            </div>

            {/* Right Column: UI Mockup */}
            <div class="relative w-full max-w-sm mx-auto lg:mr-0 pl-10 pr-6 pb-6 pt-10">
              {/* Phone Frame */}
              <div class="bg-white rounded-[2rem] shadow-2xl shadow-vesta-purple/20 overflow-hidden border border-gray-100 relative z-10 w-full max-w-[300px] mx-auto scale-100 lg:scale-[0.95] origin-center lg:origin-right">
                {/* Header */}
                <div class="bg-gradient-to-br from-purple-600 to-fuchsia-500 pt-8 pb-6 px-6 text-center text-white relative">
                  <div class="w-14 h-14 rounded-full bg-white/20 flex items-center justify-center text-xl font-bold mx-auto mb-3 backdrop-blur-md border border-white/20 overflow-hidden">
                    <img src="https://i.pravatar.cc/150?u=john" alt="John Doe" class="w-full h-full object-cover" loading="lazy" decoding="async" />
                  </div>
                  <h3 class="text-xl font-bold mb-1">John Doe</h3>
                  <p class="text-white/90 text-xs font-medium mb-2">+1 (555) 284-7190</p>
                  <div class="flex items-center justify-center gap-1.5 text-[11px] font-bold text-emerald-300">
                    <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse"></span>
                    CONNECTED — 03:42
                  </div>
                </div>
                {/* Body Content */}
                <div class="p-5">
                  <div class="mb-5">
                    <div class="flex items-center justify-between text-[10px] font-bold text-gray-400 mb-2.5 tracking-wider">
                      <div class="flex items-center gap-1.5">
                        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z"/></svg>
                        LIVE AUDIO
                      </div>
                      <span class="w-2 h-2 rounded-full bg-red-500 shadow-[0_0_8px_rgba(239,68,68,0.8)]"></span>
                    </div>
                    {/* Audio Wave */}
                    <div class="flex items-center justify-center gap-[2.5px] h-8">
                      {[3, 5, 8, 4, 3, 6, 9, 10, 8, 5, 3, 6, 4, 8, 5, 3, 7, 5, 3, 4, 6, 8, 5].map((h, i) => (
                        <div class={`w-[3px] rounded-full ${i % 3 === 0 ? 'bg-fuchsia-500 animate-pulse' : 'bg-vesta-purple'} opacity-80`} style={`height: ${h * 2}px`}></div>
                      ))}
                    </div>
                  </div>
                  
                  <div class="border-t border-gray-100 pt-5 mb-5">
                    <div class="text-[9px] font-bold text-gray-400 mb-4 tracking-wider">CALL ROUTE</div>
                    <div class="relative flex justify-between items-center px-1">
                      <div class="absolute left-6 right-6 top-1/2 -translate-y-1/2 border-t border-dashed border-gray-300 z-0"></div>
                      {pbxSteps.map(step => (
                        <div class="relative z-10 flex flex-col items-center gap-1.5">
                          <div class={`w-8 h-8 rounded-xl ${step.bg} border border-gray-200 flex items-center justify-center`}>
                            <svg class={`w-4 h-4 ${step.text}`} fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={step.icon} /></svg>
                          </div>
                          <span class="text-[8px] font-bold text-gray-400">{step.label}</span>
                        </div>
                      ))}
                    </div>
                  </div>

                  {/* Actions */}
                  <div class="flex justify-between px-3 pt-2">
                    {[
                      { icon: 'M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z', label: 'Mute' },
                      { icon: 'M17 20h5v-5M17 4h5v5M7 4H2v5M7 20H2v-5M12 4v16M4 12h16', label: 'Transfer' },
                      { icon: 'M10 9v6m4-6v6m7-3a9 9 0 11-18 0 9 9 0 0118 0z', label: 'Hold' }
                    ].map(act => (
                      <div class="flex flex-col items-center gap-2 cursor-pointer group">
                        <div class="w-10 h-10 rounded-full border border-gray-200 flex items-center justify-center text-gray-500 group-hover:bg-gray-50 group-hover:text-vesta-purple transition-colors">
                          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={act.icon} /></svg>
                        </div>
                        <span class="text-[9px] font-bold text-gray-500 group-hover:text-gray-700">{act.label}</span>
                      </div>
                    ))}
                  </div>
                </div>
              </div>

              {/* Badges */}
              <style>
                @keyframes enhancedFloatUp {
                  0%, 100% { transform: translateY(0); }
                  50% { transform: translateY(-8px); }
                }
                @keyframes enhancedFloatDown {
                  0%, 100% { transform: translateY(0); }
                  50% { transform: translateY(8px); }
                }
              </style>

              <div class="absolute lg:-left-6 top-16 bg-white rounded-xl shadow-lg border border-gray-100 px-4 py-3 z-20" style="animation: enhancedFloatUp 5s ease-in-out infinite;">
                <div class="text-[9px] font-bold text-gray-400 tracking-wider mb-0.5 uppercase">Latency</div>
                <div class="text-xl font-black text-vesta-purple">12ms</div>
              </div>
              
              <div class="absolute right-0 lg:-right-8 top-10 bg-white rounded-xl shadow-lg border border-gray-100 px-4 py-3 z-20" style="animation: enhancedFloatDown 6s ease-in-out infinite;">
                <div class="text-[9px] font-bold text-gray-400 tracking-wider mb-1 uppercase text-center">Quality</div>
                <div class="flex items-end gap-1 font-black text-gray-900 text-lg">
                  <div class="flex items-end gap-[2px] h-3 mb-0.5 mr-0.5">
                    <div class="w-1 h-1 bg-emerald-500 rounded-sm"></div>
                    <div class="w-1 h-1.5 bg-emerald-500 rounded-sm"></div>
                    <div class="w-1 h-2 bg-emerald-500 rounded-sm"></div>
                    <div class="w-1 h-2.5 bg-emerald-500 rounded-sm"></div>
                    <div class="w-1 h-3 bg-emerald-500 rounded-sm"></div>
                  </div>
                  HD
                </div>
              </div>

              <div class="absolute right-0 lg:-right-6 bottom-32 bg-emerald-50 rounded-full border border-emerald-100 py-1.5 px-3 z-20 flex items-center gap-1.5 shadow-md shadow-emerald-100/50 hover:scale-105 transition-transform cursor-pointer w-max" style="animation: enhancedFloatUp 4.5s ease-in-out infinite;">
                <svg class="w-3.5 h-3.5 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.948 11.948 0 0112 2.944a11.948 11.948 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
                <span class="text-xs font-bold text-emerald-600">Encrypted</span>
              </div>

              <div class="absolute left-0 bottom-20 bg-white rounded-full border border-gray-100 py-1.5 px-3 z-20 flex items-center gap-1.5 shadow-lg shrink-0 -translate-x-4" style="animation: enhancedFloatDown 7s ease-in-out infinite;">
                <svg class="w-3.5 h-3.5 text-vesta-purple" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" /></svg>
                <span class="text-xs font-bold text-gray-700">US-East</span>
              </div>
            </div>
          </div>
        </div>
      </section>
    ) : product.heroAnalytics ? (
      <section class="relative pt-16 pb-12 overflow-hidden bg-[#fbfbfe]">
        <style>
          @keyframes pop {
            0% { transform: scale(0.95); opacity: 0; }
            100% { transform: scale(1); opacity: 1; }
          }
          .animate-pop {
            animation: pop 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
          }
        </style>
        <div class="absolute inset-0 bg-[url('/noise.png')] opacity-[0.02] mix-blend-overlay pointer-events-none"></div>
        <div class="absolute top-0 right-0 w-[60%] h-full opacity-10 pointer-events-none">
          <div class="absolute top-1/4 right-0 w-[400px] h-[400px] bg-purple-400 blur-[100px] rounded-full"></div>
        </div>

        <div class="container mx-auto px-6 max-w-7xl relative z-10">
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
            {/* Left Column: Text */}
            <div class="max-w-xl">
              <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-purple-100 text-purple-700 text-xs font-bold mb-8 uppercase tracking-widest">
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 20V10M18 20V4M6 20v-4"/></svg>
                {product.heroAnalytics.badge}
              </div>
              <h1 class="text-5xl lg:text-7xl font-black text-slate-900 tracking-tight leading-[1.1] mb-6">
                {product.heroAnalytics.h1}<br/>
                <span class="bg-gradient-to-r from-purple-600 to-fuchsia-500 bg-clip-text text-transparent">
                  {product.heroAnalytics.h1Highlight}
                </span>
              </h1>
              <p class="max-w-xl text-lg lg:text-xl text-slate-600 mb-12 leading-relaxed font-medium">
                {product.heroAnalytics.description}
              </p>
              <div class="flex flex-col sm:flex-row gap-6">
                <a href="/contact" class="px-10 py-5 bg-gradient-to-r from-purple-600 to-indigo-600 hover:scale-105 active:scale-95 text-white font-black rounded-full transition-all shadow-[0_10px_30px_rgba(124,58,237,0.3)]">
                  {product.heroAnalytics.primaryButton}
                </a>
                <a href="/contact" class="px-10 py-5 bg-white border border-slate-200 hover:bg-slate-50 text-slate-900 font-black rounded-full transition-all hover:scale-105 active:scale-95 shadow-sm">
                  {product.heroAnalytics.secondaryButton}
                </a>
              </div>
            </div>

            {/* Right Column: Dashboard Mockup */}
            <div class="relative w-full max-w-sm mx-auto lg:mr-0 pt-6 pb-10">
              {/* Main Dashboard Card */}
              <div class="bg-white rounded-[32px] shadow-2xl shadow-gray-200/50 border border-gray-100 relative z-10 overflow-hidden transform lg:scale-[0.75]">
                {/* Header */}
                <div class="bg-gradient-to-r from-purple-600 to-indigo-700 px-8 py-5 flex items-center justify-between text-white">
                  <div>
                    <div class="font-bold text-lg leading-tight">Analytics Dashboard</div>
                    <div class="text-xs text-purple-200/60 font-medium">Real-time performance metrics</div>
                  </div>
                  <div class="bg-white/10 backdrop-blur-md rounded-full px-3 py-1 flex items-center gap-2 border border-white/10">
                    <span class="w-1.5 h-1.5 bg-emerald-400 rounded-full animate-pulse shadow-[0_0_8px_rgba(52,211,153,0.8)]"></span>
                    <span class="text-[10px] font-black tracking-widest uppercase text-white">LIVE</span>
                  </div>
                </div>

                {/* KPI Cards */}
                <div class="grid grid-cols-3 divide-x divide-gray-100 border-b border-gray-100 bg-gray-50/20">
                  {analyticsKpis.map(kpi => (
                    <div class="px-6 py-6 text-center">
                      <div class="text-[10px] font-black text-gray-400 mb-1 tracking-widest uppercase">{kpi.label}</div>
                      <div class="text-2xl font-black text-slate-900 flex items-center justify-center gap-1">
