---
import MainLayout from "../layouts/MainLayout.astro";
import productsData from "../data/products.json";

interface Props {
  productId: string;
}

const { productId } = Astro.props;
const product = productsData.items.find((p) => p.id === productId);

// Redirect to 404 if product not found
if (!product) {
  Astro.redirect("/404");
  // Exit early to prevent rendering
  throw new Error("Product not found");
}

const iconMap: Record<string, string> = {
  phone:
    '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />',
  globe:
    '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />',
  shield:
    '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.948 11.948 0 0112 2.944a11.948 11.948 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />',
  zap: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />',
  users:
    '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />',
  server:
    '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01" />',
  activity:
    '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />',
  network:
    '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.111 16.404a5.5 5.5 0 017.778 0M12 20h.01m-7.08-7.071c3.904-3.905 10.236-3.905 14.141 0M1.394 9.393c5.857-5.857 15.355-5.857 21.213 0" />',
  bot: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />',
  message:
    '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />',
  brain:
    '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />',
  calendar:
    '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />',
};
---

<MainLayout
  title={`${product.name} - ${product.hero.subtitle} | VestaCall`}
  description={product.shortDescription}
  pathname={product.url}
  breadcrumbs={[
    { name: "Home", url: "/" },
    { name: "Products", url: "/products" },
    { name: product.name, url: product.url },
  ]}
  productSchema={{
    "@context": "https://schema.org",
    "@type": "Product",
    name: product.name,
    description: product.description,
    url: `https://vestacall.com${product.url}`,
    category: product.badge,
    offers: {
      "@type": "Offer",
      priceCurrency: "USD",
      price:
        product.pricing &&
        typeof product.pricing === "string" &&
        product.pricing.includes("$")
          ? product.pricing.replace(/[^0-9.]/g, "")
          : "0",
      availability: "https://schema.org/InStock",
      priceSpecification: {
        price:
          product.pricing &&
          typeof product.pricing === "string" &&
          product.pricing.includes("$")
            ? product.pricing.replace(/[^0-9.]/g, "")
            : "0",
        priceCurrency: "USD",
      },
    },
    featureList: product.features,
    keywords: product.keywords.join(", "),
    brand: {
      "@type": "Brand",
      name: "VestaCall",
    },
    aggregateRating: {
      "@type": "AggregateRating",
      ratingValue: "4.8",
      reviewCount: "2500",
    },
  }}
>
  <section
    class="relative pt-12 pb-16 lg:pb-24 overflow-hidden bg-gradient-to-br from-gray-50 via-white to-vesta-purple/5"
  >
    <div
      class="absolute top-0 right-0 w-[600px] h-[600px] bg-vesta-purple/10 rounded-full blur-[150px] pointer-events-none"
    >
    </div>
    <div
      class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-fuchsia-200/10 rounded-full blur-[120px] pointer-events-none"
    >
    </div>

    <div class="container mx-auto px-6 max-w-6xl relative z-10">
      <div class="max-w-3xl mx-auto text-center">
        <div
          class="inline-flex items-center gap-2 bg-vesta-purple/10 border border-vesta-purple/20 rounded-full px-4 py-2 mb-6"
        >
          <svg
            class="w-4 h-4 text-vesta-purple"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            set:html={iconMap[product.icon] || iconMap.phone}
          />
          <span class="text-sm font-bold text-vesta-purple"
            >{product.badge}</span
          >
        </div>
        <h1
          class="text-4xl md:text-6xl lg:text-7xl font-black text-gray-900 tracking-tight leading-tight mb-6"
        >
          {product.hero.h1}
        </h1>
        <p class="text-2xl md:text-3xl text-vesta-purple font-bold mb-6">
          {product.hero.subtitle}
        </p>
        <p
          class="text-xl text-gray-600 max-w-2xl mx-auto leading-relaxed font-medium mb-10"
        >
          {product.hero.description}
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href="/contact"
            class="btn-primary hover:scale-105 transition-transform"
          >
            Start Free Trial
          </a>
          <a
            href="/contact"
            class="btn-secondary hover:scale-105 transition-transform"
          >
            Book a Demo
          </a>
        </div>
      </div>
    </div>
  </section>

  {
    product.benefits && product.benefits.length > 0 && (
      <section class="py-24 bg-white border-t border-gray-100">
        <div class="container mx-auto px-6 max-w-4xl">
          <h2 class="text-4xl font-black text-gray-900 tracking-tight mb-12 text-center">
            Why Choose{" "}
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-vesta-purple to-fuchsia-600">
              VestaCall
            </span>
          </h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {product.benefits.map((benefit) => (
              <div class="flex items-center gap-4 bg-gray-50 border border-gray-100 rounded-2xl p-5 hover:border-vesta-purple/20 transition-all">
                <svg
                  class="w-6 h-6 text-vesta-purple flex-shrink-0"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M5 13l4 4L19 7"
                  />
                </svg>
                <span class="text-gray-700 font-medium">{benefit}</span>
              </div>
            ))}
          </div>
        </div>
      </section>
    )
  }

  {
    product.featureList && product.featureList.length > 0 && (
      <section class="py-24 bg-gray-50 border-t border-gray-200">
        <div class="container mx-auto px-6 max-w-6xl">
          <div class="text-center mb-16">
            <h2 class="text-4xl md:text-5xl font-black text-gray-900 tracking-tight mb-4">
              Powerful Features
            </h2>
            <p class="text-gray-600 text-lg font-medium max-w-2xl mx-auto">
              Everything you need to succeed.
            </p>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {product.featureList.map((feature) => (
              <div class="bg-white border border-gray-100 rounded-3xl p-8 hover:shadow-lg hover:border-vesta-purple/20 transition-all duration-300 group">
                <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-vesta-purple to-fuchsia-600 flex items-center justify-center mb-6 shadow-lg shadow-vesta-purple/20 group-hover:scale-110 transition-transform">
                  <svg
                    class="w-7 h-7 text-white"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                    set:html={iconMap[feature.icon] || iconMap.phone}
                  />
                </div>
                <h3 class="text-xl font-bold text-gray-900 mb-3">
                  {feature.title}
                </h3>
                <p class="text-gray-600 font-medium leading-relaxed">
                  {feature.description}
                </p>
              </div>
            ))}
          </div>
        </div>
      </section>
    )
  }

  <section class="py-20 bg-gray-50 border-t border-gray-100">
    <div class="container mx-auto px-6 max-w-3xl text-center">
      <h2
        class="text-3xl md:text-4xl font-black text-gray-900 tracking-tight mb-4"
      >
        Ready to get started?
      </h2>
      <p class="text-gray-600 text-lg font-medium mb-8">
        Start your 14-day free trial. No credit card required.
      </p>
      <a
        href="/"
        class="inline-flex items-center gap-2 text-vesta-purple font-bold hover:underline text-lg"
      >
        <svg
          class="w-5 h-5"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg
        >
        Back to Home
      </a>
    </div>
  </section>
</MainLayout>
