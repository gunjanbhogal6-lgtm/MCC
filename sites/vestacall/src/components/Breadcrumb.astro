---
import seoData from '../data/seo.json';

interface Props {
  pathname: string;
  items?: Array<{ name: string; url: string }>;
}

const { pathname, items } = Astro.props;

// Build breadcrumb items
const pathParts = pathname.split('/').filter(Boolean);
const breadcrumbItems = items || [];

if (!items) {
  // Only add Home if we're not already on the home page
  if (pathname !== '/') {
    breadcrumbItems.push({ name: 'Home', url: '/' });
    
    let currentPath = '';
    for (const part of pathParts) {
      currentPath += `/${part}`;
      // Skip if this part would create a duplicate "Home"
      if (currentPath === '/') continue;
      
      const name = part
        .replace(/-/g, ' ')
        .replace(/\b\w/g, l => l.toUpperCase());
      breadcrumbItems.push({ name, url: currentPath });
    }
  }
}

// Schema.org BreadcrumbList
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": breadcrumbItems.map((item, index) => ({
    "@type": "ListItem",
    "position": index + 1,
    "name": item.name,
    "item": `${seoData.pages["/"] ? "https://vestacall.com" : ""}${item.url}`
  }))
};
---

<!-- Breadcrumb Navigation -->
<nav aria-label="Breadcrumb" class="py-4 px-6 bg-gray-50 border-b border-gray-100">
  <ol class="flex items-center gap-2 text-sm max-w-6xl mx-auto" itemscope itemtype="https://schema.org/BreadcrumbList">
    {breadcrumbItems.map((item, index) => (
      <li class="flex items-center gap-2" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
        {index > 0 && (
          <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        )}
        {index === breadcrumbItems.length - 1 ? (
          <span class="text-gray-900 font-medium" itemprop="name">{item.name}</span>
        ) : (
          <a href={item.url} class="text-gray-500 hover:text-vesta-purple transition-colors" itemprop="item">
            <span itemprop="name">{item.name}</span>
          </a>
        )}
        <meta itemprop="position" content={(index + 1).toString()} />
      </li>
    ))}
  </ol>
</nav>

<!-- Breadcrumb Schema -->
<script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
