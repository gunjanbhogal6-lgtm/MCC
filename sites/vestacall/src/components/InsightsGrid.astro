---
import { User, ArrowRight } from 'lucide-astro';

const insights = [
  { 
    tag: "Carrier Infrastructure", 
    tagColor: "text-vesta-purple", 
    title: "Understanding Global Connectivity: Why Carrier Quality Matters", 
    desc: "Discover how bypassing public congestion impacts ASR/PDD metrics.", 
    author: "Engineering Staff",
    link: "#"
  },
  { 
    tag: "Cost Optimization", 
    tagColor: "text-fuchsia-500", 
    title: "Stop Paying for Seconds You Don't Use: The Business Case for 1/1 Billing", 
    desc: "How precise billing increments save massive overhead money.", 
    author: "Billing Team",
    link: "#"
  },
  { 
    tag: "Security & Compliance", 
    tagColor: "text-blue-500", 
    title: "Combatting Spoofing: How STIR/SHAKEN Protects Your Brand", 
    desc: "The importance of Caller ID authentication and legal traffic routing.", 
    author: "Compliance Dept.",
    link: "#"
  }
];
---

<section class="py-24 bg-gray-50 border-t border-gray-100">
  <div class="container mx-auto px-6 max-w-7xl">
    <div class="flex flex-col md:flex-row justify-between items-end mb-16 gap-6">
      <div>
        <h2 class="text-4xl md:text-5xl font-black text-gray-900 mb-4 tracking-tight">
          Evergreen <span class="text-transparent bg-clip-text bg-gradient-to-r from-vesta-purple to-fuchsia-600">Insights</span>
        </h2>
        <p class="text-xl text-gray-500 font-medium max-w-2xl">
          Deep-dives into carrier quality, billing optimization, and compliance from our engineering and leadership teams.
        </p>
      </div>
      <a href="/blog" class="shrink-0 flex items-center gap-2 px-6 py-3 rounded-full bg-white border border-gray-200 text-gray-900 font-bold hover:border-vesta-purple hover:text-vesta-purple transition-all shadow-sm">
        View All Articles <svg class="w-4.5 h-4.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
      </a>
    </div>

    <div class="grid md:grid-cols-2 gap-8">
      {insights.map((article) => (
        <a href={article.link} class="block group h-full">
          <div class="bg-white rounded-3xl p-8 border border-gray-100 h-full hover:border-vesta-purple/30 hover:shadow-xl transition-all duration-300 flex flex-col justify-between">
            <div>
              <span class={`text-xs font-bold uppercase tracking-wider mb-4 block ${article.tagColor}`}>
                {article.tag}
              </span>
              <h3 class="text-2xl font-bold text-gray-900 mb-4 group-hover:text-vesta-purple transition-colors leading-tight">
                {article.title}
              </h3>
              <p class="text-gray-600 font-medium mb-8 leading-relaxed">
                {article.desc}
              </p>
            </div>
            <div class="flex items-center justify-between text-sm text-gray-500 font-bold border-t border-gray-100 pt-6">
              <span class="flex items-center gap-2">
                <User class="w-4 h-4" />
                {article.author}
              </span>
              <span class="flex items-center gap-2 group-hover:text-vesta-purple transition-colors">
                Read Article <ArrowRight class="w-4 h-4" />
              </span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
