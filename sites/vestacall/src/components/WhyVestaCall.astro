---
import homeData from '../data/home.json';

const whyData = homeData.why_vestacall;
---

<section class="py-24 bg-vesta-dark relative overflow-hidden">
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-vesta-purple/10 rounded-full blur-[150px] pointer-events-none"></div>

  <div class="container mx-auto px-6 max-w-6xl relative z-10">
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-5xl font-black text-white tracking-tight mb-4">
        {whyData.title}
      </h2>
      <p class="text-white/60 text-lg font-medium">
        {whyData.description}
      </p>
    </div>

    <div class="grid md:grid-cols-4 gap-8">
      {whyData.items.map((item) => (
        <div class="text-center">
          <div class="bg-vesta-purple rounded-2xl p-6 inline-block mb-4">
            <p class="text-4xl font-black text-white">{item.number}</p>
          </div>
          <h3 class="text-xl font-bold text-white mb-2">{item.label}</h3>
          <p class="text-white/60 text-sm italic">"{item.testimonial}"</p>
        </div>
      ))}
    </div>
  </div>
</section>
