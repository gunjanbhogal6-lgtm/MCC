---
// src/components/home/Testimonials.astro
---

<section class="py-24 bg-[#050110] relative overflow-hidden">
  {/* Grid background using lines */}
  <div class="absolute inset-0 opacity-[0.03] pointer-events-none">
    <div class="absolute inset-0" style="background-image: linear-gradient(#6d28d9 1px, transparent 1px), linear-gradient(90deg, #6d28d9 1px, transparent 1px); background-size: 80px 80px;"></div>
  </div>

  <div class="container mx-auto px-6 relative z-10">
    <div class="grid lg:grid-cols-[1fr_1.2fr] gap-20 items-center">
      
      {/* Left Content */}
      <div class="max-w-md">
        <h2 class="text-4xl sm:text-6xl font-black text-white mb-8 leading-tight tracking-tight">
          Voices of <br/>
          <span class="bg-gradient-to-r from-[#c084fc] via-[#818cf8] to-[#22d3ee] bg-clip-text text-transparent italic">
            Success
          </span>
        </h2>
        <p class="text-[#8e8a9a] text-lg mb-12 leading-relaxed font-medium max-w-sm">
          Don't just take our word for it. Hear how forward-thinking leaders are redefining global communication with VestaCall.
        </p>
        
        <div class="flex gap-4">
          <button class="w-10 h-10 rounded-full border border-white/10 flex items-center justify-center text-white/40 hover:text-white hover:border-white/30 transition-all">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"></path></svg>
          </button>
          <button class="w-10 h-10 rounded-full border border-white/10 flex items-center justify-center text-white/40 hover:text-white hover:border-white/30 transition-all">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"></path></svg>
          </button>
        </div>
      </div>

      {/* Testimonial Card */}
      <div class="relative">
        <div class="absolute -inset-10 bg-purple-600/10 rounded-full blur-[100px] opacity-50"></div>
        
        <div class="relative bg-white rounded-[40px] sm:rounded-[60px] p-8 sm:p-16 shadow-2xl">
          {/* Stars */}
          <div class="flex gap-1.5 mb-10">
            {[1, 2, 3, 4, 5].map(() => (
              <svg class="w-5 h-5 text-[#ffb800] fill-current" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>

          <blockquote class="text-2xl sm:text-[32px] font-black text-slate-900 leading-[1.3] mb-12 sm:mb-16 tracking-tight">
            "VestaCall transformed our entire support architecture in days. We now handle 40% more customer interactions globally with the exact same team."
          </blockquote>

          <div class="flex flex-col sm:flex-row items-center sm:justify-between gap-8 sm:gap-6 pt-10 border-t border-slate-50">
            <div class="flex items-center gap-4">
              <div class="relative">
                <img src="https://i.pravatar.cc/150?u=sarah" alt="Sarah Jenkins" class="w-14 h-14 rounded-full object-cover ring-4 ring-slate-50 shadow-sm" loading="lazy" decoding="async" />
                <div class="absolute -bottom-1 -right-1 w-6 h-6 bg-[#6d28d9] rounded-full flex items-center justify-center text-[12px] text-white font-serif italic border-2 border-white">
                   ”
                </div>
              </div>
              <div class="text-center sm:text-left">
                <h4 class="text-[#0f172a] font-black text-xl leading-none mb-2">Sarah Jenkins</h4>
                <p class="text-[#64748b] text-sm font-semibold tracking-wide uppercase">
                  VP of Operations · <span class="text-[#6d28d9]">Nexus Enterprises</span>
                </p>
              </div>
            </div>

            <div class="px-8 py-5 bg-gradient-to-br from-[#7c3aed] to-[#5b21b6] rounded-[24px] text-white shadow-[0_15px_30px_rgba(124,58,237,0.4)] text-center sm:text-left">
              <div class="text-3xl font-black leading-none mb-1">+40%</div>
              <div class="text-[9px] font-black uppercase tracking-[0.1em] opacity-90">Interaction Volume</div>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>


    </div>
  </div>
</section>
