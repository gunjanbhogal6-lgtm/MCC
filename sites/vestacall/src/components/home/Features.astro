---
// src/components/home/Features.astro
---
<section class="py-32 bg-[#fbfcff]">
  <div class="container mx-auto px-6">
    <div class="max-w-4xl mx-auto text-center mb-24">
      <div class="inline-flex items-center gap-2 px-4 py-1 rounded-full border border-purple-200 bg-white text-purple-600 text-xs font-bold uppercase tracking-widest mb-8">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        Next-Generation Operations
      </div>
      <h2 class="text-4xl sm:text-6xl md:text-7xl font-black text-slate-900 mb-8 tracking-tight">
        Empower Your <br/>
        <span class="bg-gradient-to-r from-purple-600 to-indigo-500 bg-clip-text text-transparent">Support Arsenal</span>
      </h2>
      <p class="text-xl text-slate-500 leading-relaxed max-w-3xl mx-auto">
        VestaCall ensures faster response times, personalized interactions, and reduced call abandonment. 
        Transmute raw conversations into long-term relationships.
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-10 mb-10">
      {/* AI-Driven Insights */}
      <div class="group relative bg-white rounded-[40px] p-12 border border-slate-100 shadow-[0_20px_50px_rgba(0,0,0,0.02)] hover:shadow-xl transition-all duration-500 overflow-hidden">
        <div class="w-16 h-16 bg-purple-600 rounded-3xl flex items-center justify-center mb-10 shadow-lg shadow-purple-200 group-hover:scale-110 transition-transform duration-500">
          <svg class="w-8 h-8 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2v20M2 12h20" /></svg>
        </div>
        <h3 class="text-3xl font-bold text-slate-900 mb-4">AI-Driven Insights</h3>
        <p class="text-lg text-slate-500 mb-10 leading-relaxed">
          Real-time analytics, instant sentiment processing, and deep performance tracking to empower your agents with psychic-level context.
        </p>
        <div class="mt-auto flex items-center gap-3">
           <div class="w-4 h-4 rounded-full bg-purple-600 animate-pulse outline outline-offset-4 outline-purple-200"></div>
           <div class="h-2 w-32 bg-slate-100 rounded-full overflow-hidden">
              <div class="h-full bg-purple-600 w-0 group-hover:w-full transition-all duration-1000 ease-out"></div>
           </div>
           <div class="flex gap-1.5">
              <div class="w-2.5 h-2.5 rounded-full bg-cyan-400 group-hover:animate-bounce [animation-delay:-0.3s]"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-cyan-400 group-hover:animate-bounce [animation-delay:-0.15s]"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-cyan-400 group-hover:animate-bounce"></div>
           </div>
        </div>
      </div>

      {/* Live Reporting */}
      <div class="group relative bg-white rounded-[40px] p-12 border border-slate-100 shadow-[0_20px_50px_rgba(0,0,0,0.02)] hover:shadow-xl transition-all duration-500 overflow-hidden hidden sm:block">
        <div class="w-16 h-16 bg-blue-500 rounded-3xl flex items-center justify-center mb-10 shadow-lg shadow-blue-100 group-hover:scale-110 transition-transform duration-500">
          <svg class="w-8 h-8 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
        </div>
        <h3 class="text-3xl font-bold text-slate-900 mb-4">Live Reporting</h3>
        <p class="text-lg text-slate-500 mb-10 leading-relaxed">
          Track KPIs like global volume, SLA times, and peak-hour productivity instantly with our real-time dashboard.
        </p>
        <div class="flex items-end gap-3 h-16 relative">
           <div class="w-6 bg-slate-100 rounded-t-lg h-[40%] group-hover:h-[90%] transition-all duration-700 delay-75 shadow-inner"></div>
           <div class="w-6 bg-purple-500 rounded-t-lg h-[80%] group-hover:h-[40%] transition-all duration-700 delay-150"></div>
           <div class="w-6 bg-blue-500 rounded-t-lg h-[60%] group-hover:h-[100%] transition-all duration-700 delay-225"></div>
           <div class="w-6 bg-cyan-400 rounded-t-lg h-[100%] group-hover:h-[60%] transition-all duration-700 delay-300"></div>
           <div class="w-6 bg-blue-400 rounded-t-lg h-[75%] group-hover:h-[85%] transition-all duration-700 delay-375"></div>
           {/* Shimmer line */}
           <div class="absolute inset-0 bg-gradient-to-r from-transparent via-white/30 to-transparent -translate-x-full group-hover:translate-x-full transition-transform duration-1000"></div>
        </div>
      </div>
    </div>

    <div class="grid md:grid-cols-3 gap-10">
      {/* Omnichannel */}
      <div class="group bg-white rounded-[40px] p-10 border border-slate-100 shadow-sm relative overflow-hidden transition-all duration-500 hover:shadow-lg">
        <div class="w-14 h-14 bg-red-500 rounded-2xl flex items-center justify-center mb-8 shadow-lg shadow-red-100 group-hover:scale-110 transition-transform">
          <svg class="w-6 h-6 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        </div>
        <h3 class="text-2xl font-bold text-slate-900 mb-4">Omnichannel</h3>
        <p class="text-slate-500 leading-relaxed mb-8">Voice, Live Chat, Email, and Social Media — fused into a singular pane of glass.</p>
        <div class="absolute bottom-10 right-10 flex items-center justify-center w-12 h-12">
           <div class="absolute w-8 h-8 border-2 border-red-200 rounded-full group-hover:animate-ping opacity-20"></div>
           <div class="relative flex gap-1.5">
              <div class="w-4 h-4 rounded-full bg-red-400 group-hover:scale-125 transition-transform duration-300"></div>
              <div class="w-4 h-4 rounded-full bg-red-200 group-hover:translate-y-[-10px] transition-transform duration-300 delay-100"></div>
           </div>
        </div>
      </div>

      {/* Smart Routing */}
      <div class="group bg-white rounded-[40px] p-10 border border-slate-100 shadow-sm relative overflow-hidden transition-all duration-500 hover:shadow-lg hidden sm:block">
        <div class="w-14 h-14 bg-orange-500 rounded-2xl flex items-center justify-center mb-8 shadow-lg shadow-orange-100 group-hover:scale-110 transition-transform">
          <svg class="w-6 h-6 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
        </div>
        <h3 class="text-2xl font-bold text-slate-900 mb-4">Smart Routing</h3>
        <p class="text-slate-500 leading-relaxed mb-8">Automatically cascade calls based on agent skillsets and real-time availability.</p>
        <div class="absolute bottom-10 right-10 flex flex-col gap-3">
           <div class="w-20 h-2 bg-orange-100 rounded-full overflow-hidden">
              <div class="h-full bg-orange-500 w-1/3 group-hover:translate-x-[200%] transition-transform duration-1000 ease-in-out infinite"></div>
           </div>
           <div class="w-16 h-2 bg-orange-50 rounded-full overflow-hidden ml-auto">
              <div class="h-full bg-orange-400 w-1/2 group-hover:translate-x-[-150%] transition-transform duration-1500 ease-in-out"></div>
           </div>
        </div>
      </div>

      {/* Enterprise Security */}
      <div class="bg-white rounded-[40px] p-10 border border-slate-100 shadow-sm relative overflow-hidden group hover:scale-[1.02] hover:shadow-xl transition-all duration-500">
        <div class="w-16 h-16 bg-purple-600 rounded-2xl flex items-center justify-center mb-8 shadow-lg shadow-purple-100 group-hover:shadow-purple-200 group-hover:scale-110 transition-all duration-500">
          <svg class="w-8 h-8 text-white group-hover:animate-pulse" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <h3 class="text-2xl font-bold text-slate-900 mb-2">Enterprise Security</h3>

        <p class="text-purple-600 font-bold mb-6 text-sm uppercase tracking-wider">SOC-2 TYPE II CERTIFIED</p>
        <p class="text-slate-500 leading-relaxed">Multi-layered DDoS protection and end-to-end encryption for every call.</p>
        <div class="absolute top-10 right-10 group-hover:text-purple-600 transition-colors duration-300">
           <svg class="w-12 h-12 text-slate-100 group-hover:animate-[bounce_0.5s_infinite] transition-opacity" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
        </div>
        <div class="absolute -bottom-10 -right-10 w-24 h-24 bg-purple-50 rounded-full group-hover:scale-150 transition-transform duration-1000"></div>
      </div>
    </div>


  </div>
</section>


