---
// src/components/home/WorldMapAnimation.astro
import landTopoJSON from "../../data/land-110m.json";
// @ts-ignore
import { feature } from "topojson-client";
// @ts-ignore
import { geoNaturalEarth1, geoPath } from "d3-geo";

const width = 800;
const height = 450;

// @ts-ignore
const land = feature(landTopoJSON, landTopoJSON.objects.land);
const projection = geoNaturalEarth1().fitExtent(
  [
    [10, 10],
    [width - 10, height - 10],
  ],
  land,
);

const pathGen = geoPath(projection);
const landPathD = pathGen(land) || "";

// Nodes from the screenshot
const nodes = [
  { name: "West US", lon: -122.4194, lat: 37.7749 },
  { name: "Mid US", lon: -100, lat: 40 },
  { name: "East US", lon: -74.006, lat: 40.7128 },
  { name: "Mexico", lon: -99, lat: 19 },
  { name: "Brazil", lon: -46.6, lat: -23.5 },
  { name: "Argentina", lon: -58.3, lat: -34.6 },
  { name: "UK", lon: -0.1, lat: 51.5 },
  { name: "Germany", lon: 13.4, lat: 52.5 },
  { name: "Europe Main", lon: 10, lat: 48 },
  { name: "Egypt", lon: 31, lat: 30 },
  { name: "Dubai", lon: 55, lat: 25 },
  { name: "South Africa", lon: 18, lat: -34 },
  { name: "India", lon: 77, lat: 20 },
  { name: "Russia West", lon: 37, lat: 55 },
  { name: "China East", lon: 121, lat: 31 },
  { name: "Japan", lon: 140, lat: 36 },
  { name: "SE Asia", lon: 101, lat: 3 },
  { name: "Australia", lon: 144, lat: -37 },
];

const projectedNodes = nodes.map((node) => {
  const coords = projection([node.lon, node.lat]);
  return { ...node, x: coords ? coords[0] : 0, y: coords ? coords[1] : 0 };
});

// Connections based on image
const connections = [
  { from: 2, to: 6 }, // East US to UK
  { from: 16, to: 17 }, // SE Asia to Australia
  { from: 0, to: 2 }, // West to East US
];

const connectionPaths = connections.map(({ from, to }) => {
  const start = projectedNodes[from];
  const end = projectedNodes[to];
  const dx = end.x - start.x;
  const dy = end.y - start.y;
  const dr = Math.sqrt(dx * dx + dy * dy);
  
  return `M${start.x},${start.y} A${dr},${dr} 0 0,1 ${end.x},${end.y}`;
});

// Pass data to client script
const mapData = {
  nodes: projectedNodes,
};
---

<div class="world-map-wrap" id="world-map-root">
  <svg viewBox={`0 0 ${width} ${height}`} class="world-map-svg" id="map-svg">
    <defs>
      <filter id="ray-glow">
        <feGaussianBlur stdDeviation="2" result="blur" />
        <feComposite in="SourceGraphic" in2="blur" operator="over" />
      </filter>
      <linearGradient id="ray-grad" x1="0%" y1="0%" x2="100%" y2="0%">
        <stop offset="0%" stop-color="rgba(124, 58, 237, 0)" />
        <stop offset="50%" stop-color="rgba(124, 58, 237, 0.8)" />
        <stop offset="100%" stop-color="#7C3AED" />
      </linearGradient>
    </defs>

    <path d={landPathD} class="land-path" />
    
    {/* Base connections */}
    {connectionPaths.map((d) => (
      <path d={d} fill="none" stroke="#7C3AED" stroke-width="1" stroke-linecap="round" class="connection-line-base" />
    ))}

    {/* Ray container (will be populated by JS) */}
    <g id="rays-layer"></g>

    {/* Nodes */}
    {projectedNodes.map((node) => (
      <g class="map-node">
        <circle cx={node.x} cy={node.y} r="10" class="node-ripple-1" />
        <circle cx={node.x} cy={node.y} r="6" class="node-ripple-2" />
        <circle cx={node.x} cy={node.y} r="3" class="node-core" />
      </g>
    ))}
  </svg>
</div>

<script is:inline define:vars={{ mapData }}>
  const raysLayer = document.getElementById('rays-layer');
  const nodes = mapData.nodes;

  function createLiveRay() {
    // Pick two random nodes
    const fromIdx = Math.floor(Math.random() * nodes.length);
    let toIdx = Math.floor(Math.random() * nodes.length);
    while (toIdx === fromIdx) {
      toIdx = Math.floor(Math.random() * nodes.length);
    }

    const start = nodes[fromIdx];
    const end = nodes[toIdx];
    
    const dx = end.x - start.x;
    const dy = end.y - start.y;
    const dr = Math.sqrt(dx * dx + dy * dy);
    
    const path = document.createElementNS("http://www.w3.org/2000/svg", "path");
    const d = `M${start.x},${start.y} A${dr},${dr} 0 0,${Math.random() > 0.5 ? 1 : 0} ${end.x},${end.y}`;
    
    path.setAttribute('d', d);
    path.setAttribute('fill', 'none');
    path.setAttribute('stroke', 'url(#ray-grad)');
    path.setAttribute('stroke-width', '1.5');
    path.setAttribute('stroke-linecap', 'round');
    path.style.filter = 'url(#ray-glow)';
    
    // Animate ray
    const totalPathLength = path.getTotalLength();
    const rayLength = 100 + Math.random() * 50; // Longer rays
    path.style.strokeDasharray = `${rayLength} ${totalPathLength}`;
    path.style.strokeDashoffset = totalPathLength;
    
    const duration = 2000 + Math.random() * 1500; // Slightly slower/smoother
    
    raysLayer.appendChild(path);

    const animation = path.animate([
      { strokeDashoffset: totalPathLength, opacity: 0 },
      { strokeDashoffset: totalPathLength - 20, opacity: 1, offset: 0.1 },
      { strokeDashoffset: -rayLength + 20, opacity: 1, offset: 0.9 },
      { strokeDashoffset: -rayLength, opacity: 0 }
    ], {
      duration: duration,
      easing: 'cubic-bezier(0.4, 0, 0.2, 1)'
    });

    animation.onfinish = () => {
      path.remove();
    };
  }

  // Initial batch
  for(let i=0; i<3; i++) setTimeout(createLiveRay, Math.random() * 2000);

  // Continuous spawn
  setInterval(createLiveRay, 800);
</script>

<style>
  .world-map-wrap {
    width: 100%;
    height: 100%;
    background: transparent;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    padding: 2rem;
  }
  
  .world-map-svg {
    width: 100%;
    height: auto;
    filter: drop-shadow(0 10px 30px rgba(124, 58, 237, 0.05));
    overflow: visible;
  }
  
  .land-path {
    fill: #e9e2ff;
    stroke: #c8b8ff;
    stroke-width: 0.8;
    transition: fill 0.3s ease;
  }
  
  .connection-line-base {
    opacity: 0.3;
    stroke-dasharray: 4 4;
  }
  
  .node-core {
    fill: #6d28d9;
  }
  
  .node-ripple-1 {
    fill: #6d28d9;
    opacity: 0.1;
    animation: ripple 2s infinite;
  }
  
  .node-ripple-2 {
    fill: #6d28d9;
    opacity: 0.2;
    animation: ripple 2s infinite 0.5s;
  }
  
  @keyframes ripple {
    0% { transform: scale(1); opacity: 0.3; }
    100% { transform: scale(2.5); opacity: 0; }
  }
  
  .map-node circle {
    transform-box: fill-box;
    transform-origin: center;
  }
</style>

