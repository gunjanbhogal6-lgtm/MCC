---
// src/components/home/NetworkReliability.astro
---
<section class="py-32 bg-[#0b0416] relative overflow-hidden">
  <div class="container mx-auto px-6">
    <div class="grid lg:grid-cols-2 gap-20 items-center">
      <div class="text-left">
        <div class="inline-flex items-center gap-3 px-4 py-1.5 rounded-full border border-purple-500/20 bg-purple-500/10 text-purple-400 text-sm font-bold mb-10 uppercase tracking-widest">
           <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
           The Airlines of Voice Communication
        </div>
        
        <h2 class="text-4xl md:text-6xl font-black text-white mb-10 tracking-tight leading-none">
          Unshakable <br/>
          <span class="bg-gradient-to-r from-purple-500 to-indigo-400 bg-clip-text text-transparent">
            Network Reliability
          </span>
        </h2>
        
        <p class="text-xl text-white/40 mb-14 leading-relaxed max-w-xl">
          No dropped packets. No jitter. Just crystal-clear, uninterrupted connectivity. 
          Whether you are a global carrier or a growing enterprise, VestaCall provides 
          the backbone for the digital age.
        </p>

        <div class="space-y-10">
          <div class="flex gap-6 items-center group">
            <div class="w-8 h-8 rounded-full border border-purple-500/30 flex items-center justify-center shrink-0 group-hover:bg-purple-500 transition-colors">
              <svg class="w-4 h-4 text-purple-400 group-hover:text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path d="M5 13l4 4L19 7"/></svg>
            </div>
            <div>
              <h4 class="text-2xl font-bold text-white mb-1">Global Wholesale Routing</h4>
              <p class="text-white/30 text-lg">Tier-1 connectivity bypassing public congestion.</p>
            </div>
          </div>
          <div class="flex gap-6 items-center group">
            <div class="w-8 h-8 rounded-full border border-purple-500/30 flex items-center justify-center shrink-0 group-hover:bg-purple-500 transition-colors">
              <svg class="w-4 h-4 text-purple-400 group-hover:text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path d="M5 13l4 4L19 7"/></svg>
            </div>
            <div>
              <h4 class="text-2xl font-bold text-white mb-1">High ASR / Low PDD</h4>
              <p class="text-white/30 text-lg">Precision engineered for the best connection metrics.</p>
            </div>
          </div>
          <div class="flex gap-6 items-center group">
            <div class="w-8 h-8 rounded-full border border-purple-500/30 flex items-center justify-center shrink-0 group-hover:bg-purple-500 transition-colors">
              <svg class="w-4 h-4 text-purple-400 group-hover:text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path d="M5 13l4 4L19 7"/></svg>
            </div>
            <div>
              <h4 class="text-2xl font-bold text-white mb-1">Redundant Architecture</h4>
              <p class="text-white/30 text-lg">Instant failover across distributed data centers.</p>
            </div>
          </div>
        </div>
      </div>

      <div class="relative">
        <div class="absolute -inset-20 bg-purple-600/10 blur-[120px] rounded-full animate-pulse"></div>
        <div class="relative bg-slate-900/50 border border-white/5 rounded-[40px] p-8 md:p-20 aspect-square flex items-center justify-center">
          <div class="relative w-full h-full flex items-center justify-center">
            {/* Pulsing Globe Base */}
            <div class="absolute inset-0 bg-purple-600/20 rounded-full blur-3xl animate-pulse"></div>
            <div class="relative z-10 w-48 h-48 bg-purple-600 rounded-full flex items-center justify-center shadow-[0_0_80px_rgba(124,58,237,0.5)]">
               <svg class="w-24 h-24 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                 <circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
               </svg>
            </div>
            
            {/* Orbiting dots */}
            <div class="absolute w-full h-full border border-white/5 rounded-full animate-[spin_10s_linear_infinite]">
               <div class="absolute -top-2 left-1/2 -translate-x-1/2 w-4 h-4 bg-white rounded-full shadow-[0_0_15px_rgba(255,255,255,0.8)]"></div>
            </div>
            <div class="absolute w-[80%] h-[80%] border border-white/5 rounded-full animate-[spin_15s_linear_infinite_reverse]">
               <div class="absolute -bottom-2 left-1/2 -translate-x-1/2 w-3 h-3 bg-purple-400 rounded-full shadow-[0_0_15px_rgba(167,139,250,0.8)]"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>



<style>
  @keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
  @keyframes spin-reverse {
    from { transform: rotate(0deg); }
    to { transform: rotate(-360deg); }
  }
  .animate-\[spin_20s_linear_infinite\] {
    animation: spin 20s linear infinite;
  }
  .animate-\[spin_15s_linear_infinite_reverse\] {
    animation: spin-reverse 15s linear infinite;
  }
</style>
