---
const testimonials = [
  {
    quote:
      "VestaCall transformed our entire support architecture in days. We now handle 40% more customer interactions globally with the exact same team.",
    author: "Sarah Jenkins",
    role: "VP of Operations",
    company: "Nexus Enterprises",
    image: "https://i.pravatar.cc/150?img=35",
    rating: 5,
    metric: "+40%",
    metricLabel: "Interaction Volume",
  },
  {
    quote:
      "The voice clarity is exceptional, even on satellite connections. The AI routing and live sentiment dashboard helped us identify critical churn risks instantly.",
    author: "Marcus Chen",
    role: "Head of Customer Success",
    company: "Lumina Data",
    image: "https://i.pravatar.cc/150?img=11",
    rating: 5,
    metric: "99.99%",
    metricLabel: "Uptime Reliability",
  },
  {
    quote:
      "It feels like an ultra-premium enterprise PBX, without any of the legacy hardware complexity. We ported 500 numbers in under two hours.",
    author: "Elena Rodriguez",
    role: "CTO",
    company: "FinShift",
    image: "https://i.pravatar.cc/150?img=47",
    rating: 5,
    metric: "< 2 hrs",
    metricLabel: "Deployment Time",
  },
];
---

<section class="py-32 bg-[#0b0416] relative overflow-hidden">
  <div
    class="absolute inset-0 opacity-[0.06] pointer-events-none"
    style="background-image: linear-gradient(to right, #6C2BD9 1px, transparent 1px), linear-gradient(to bottom, #6C2BD9 1px, transparent 1px); background-size: 4rem 4rem; mask-image: radial-gradient(circle at center, black 30%, transparent 80%)"
  >
  </div>
  <div
    class="absolute top-1/4 left-1/4 w-96 h-96 bg-vesta-purple/20 rounded-full blur-[128px] pointer-events-none"
  >
  </div>
  <div
    class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-fuchsia-500/10 rounded-full blur-[128px] pointer-events-none"
  >
  </div>

  <div class="container mx-auto px-6 relative z-10">
    <div class="text-center mb-16">
      <h2
        class="text-4xl md:text-6xl font-black mb-6 leading-tight text-white tracking-tight"
      >
        Voices of <br />
        <span
          class="text-transparent bg-clip-text bg-gradient-to-r from-[#d946ef] to-[#0ef5d4]"
          >Success</span
        >
      </h2>
      <p
        class="text-white/60 text-lg leading-relaxed font-medium max-w-2xl mx-auto"
      >
        Don't just take our word for it. Hear how forward-thinking leaders are
        redefining global communication with VestaCall.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {
        testimonials.map((testimonial) => (
          <div class="bg-white border border-gray-200 p-8 rounded-[2rem] shadow-xl hover:shadow-2xl hover:shadow-vesta-purple/10 transition-all duration-300">
            <div class="flex items-center gap-1 mb-6">
              {[...Array(testimonial.rating)].map((_) => (
                <svg
                  class="w-5 h-5 fill-amber-400 text-amber-400"
                  viewBox="0 0 24 24"
                >
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
                </svg>
              ))}
            </div>
            <h3 class="text-xl text-gray-900 font-bold leading-snug tracking-tight mb-6">
              "{testimonial.quote}"
            </h3>
            <div class="flex items-center gap-4 mb-6">
              <img
                src={testimonial.image}
                alt={testimonial.author}
                class="w-14 h-14 rounded-full object-cover border-2 border-white shadow-lg"
              />
              <div>
                <h4 class="text-lg font-bold text-gray-900">
                  {testimonial.author}
                </h4>
                <p class="text-gray-500 font-medium text-sm">
                  {testimonial.role} ·{" "}
                  <span class="text-vesta-purple font-bold">
                    {testimonial.company}
                  </span>
                </p>
              </div>
            </div>
            <div class="bg-vesta-purple rounded-xl p-4">
              <p class="text-2xl font-black text-white">{testimonial.metric}</p>
              <p class="text-xs font-bold text-white/80 uppercase tracking-widest mt-1">
                {testimonial.metricLabel}
              </p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
