---
import homeData from '../data/home.json';

const statsData = homeData.stats;
---

<section class="py-16 bg-white border-t border-gray-100">
  <div class="container mx-auto px-6 max-w-6xl">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 sm:gap-8 text-center">
      {statsData.map((stat) => (
        <div>
          <p class="text-4xl md:text-5xl font-black text-vesta-purple mb-2">{stat.number}</p>
          <p class="text-gray-500 font-bold text-sm uppercase tracking-wider">{stat.label}</p>
        </div>
      ))}
    </div>
  </div>
</section>
