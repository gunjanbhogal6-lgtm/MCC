---
import homeData from '../data/home.json';

const ctaData = homeData.cta;
---

<section class="py-24 relative overflow-hidden bg-gray-50 border-t border-gray-200">
  <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-vesta-purple/10 rounded-full blur-[150px] pointer-events-none"></div>
  <div class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-fuchsia-200/30 rounded-full blur-[150px] pointer-events-none"></div>

  <div class="container mx-auto px-6 relative z-10">
    <div class="bg-white border border-gray-200 rounded-3xl p-12 md:p-20 text-center shadow-xl shadow-vesta-purple/5 max-w-5xl mx-auto relative overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-vesta-purple/5 via-transparent to-fuchsia-500/5 pointer-events-none"></div>
      <div class="relative z-10">
        <h2 class="text-4xl md:text-5xl font-black mb-6 leading-tight text-gray-900 tracking-tight">
          {ctaData.title}
        </h2>
        <p class="text-lg text-gray-600 mb-10 max-w-2xl mx-auto font-medium">
          {ctaData.description}
        </p>
        <div class="flex flex-col sm:flex-row justify-center items-center gap-4">
          <a href="/contact" class="w-full sm:w-auto px-10 py-5 rounded-full bg-vesta-purple text-white font-bold text-lg hover:bg-[#5a24b5] shadow-lg transition-all hover:scale-105">
            {ctaData.primary}
          </a>
          <a href="/contact" class="w-full sm:w-auto px-10 py-5 rounded-full border border-gray-200 bg-white font-bold text-gray-900 text-lg hover:border-vesta-purple hover:text-vesta-purple transition-all shadow-sm hover:bg-gray-50">
            {ctaData.secondary}
          </a>
        </div>
        <p class="text-gray-500 text-sm mt-6">
          {ctaData.guarantee}
        </p>
      </div>
    </div>
  </div>
</section>
