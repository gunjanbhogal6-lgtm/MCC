---
import homeData from '../data/home.json';

const featuresData = homeData.features;

// Map features to relevant product pages
const featureLinks: Record<string, string> = {
  "Smart Call Routing & IVR": "/products/cloud-contact-center",
  "AI-Powered Sentiment Analysis": "/products/sentiment-analysis",
  "Global Voice Termination": "/sip-trunking",
  "24/7 AI Receptionist": "/conversational-ai",
  "Unified Omnichannel Inbox": "/products/cloud-contact-center",
  "CRM Integrations": "/products/crm-integrations"
};
---

<section class="py-24 bg-gray-50 border-t border-gray-200">
  <div class="container mx-auto px-6 max-w-6xl">
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-5xl font-black text-gray-900 tracking-tight mb-4">
        {featuresData.title}
      </h2>
      <p class="text-gray-600 text-lg font-medium max-w-2xl mx-auto">
        {featuresData.description}
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {featuresData.items.map((feature) => {
        const featureUrl = featureLinks[feature.heading];
        return (
          <div class="bg-white rounded-2xl p-8 border border-gray-100 hover:border-vesta-purple/30 hover:shadow-xl transition-all duration-300">
            <h3 class="text-xl font-bold text-gray-900 mb-3">
              {featureUrl ? (
                <a href={featureUrl} class="hover:text-vesta-purple transition-colors">
                  {feature.heading}
                </a>
              ) : (
                feature.heading
              )}
            </h3>
            <p class="text-gray-600 font-medium leading-relaxed mb-4">{feature.description}</p>
            <div class="flex flex-wrap gap-2">
              {feature.keywords.split(', ').map((keyword) => (
                <span class="text-xs font-semibold text-vesta-purple bg-vesta-purple/10 px-2 py-1 rounded-full">
                  {keyword}
                </span>
              ))}
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>
