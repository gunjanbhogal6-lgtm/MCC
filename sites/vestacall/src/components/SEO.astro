---
import siteData from "../data/site.json";
import seoData from "../data/seo.json";

interface Props {
  title?: string;
  description?: string;
  pathname: string;
  type?: "website" | "article" | "product";
  image?: string;
  publishedTime?: string;
  modifiedTime?: string;
}

const {
  title = seoData.global.metaTitle,
  description = seoData.global.metaDescription,
  pathname,
  type = "website",
  image = siteData.defaultImage,
  publishedTime,
  modifiedTime,
} = Astro.props;

const siteUrl = siteData.url;
const canonicalUrl = new URL(pathname, siteUrl).toString();
const imageUrl = new URL(image, siteUrl).toString();

const pageSEO = seoData.pages[pathname as keyof typeof seoData.pages] || {};
const finalTitle = pageSEO.title || title;
const finalDescription = pageSEO.description || description;
---

<title>{finalTitle}</title>
<meta name="title" content={finalTitle} />
<meta name="description" content={finalDescription} />
<meta name="keywords" content={seoData.global.lsiKeywords.join(", ")} />
<meta name="author" content={siteData.author} />
<meta name="robots" content="index, follow" />
<link rel="canonical" href={canonicalUrl} />
<link rel="alternate" hreflang="en" href={canonicalUrl} />
<link rel="alternate" hreflang="x-default" href={canonicalUrl} />

<meta property="og:type" content={type} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:title" content={finalTitle} />
<meta property="og:description" content={finalDescription} />
<meta property="og:image" content={imageUrl} />
<meta property="og:site_name" content={siteData.name} />
<meta property="og:locale" content="en_US" />

<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={canonicalUrl} />
<meta property="twitter:title" content={finalTitle} />
<meta property="twitter:description" content={finalDescription} />
<meta property="twitter:image" content={imageUrl} />
<meta property="twitter:site" content={siteData.twitterHandle} />

{
  type === "article" && publishedTime && (
    <meta property="article:published_time" content={publishedTime} />
  )
}
{
  type === "article" && modifiedTime && (
    <meta property="article:modified_time" content={modifiedTime} />
  )
}

<meta name="geo.region" content="US-CA" />
<meta name="geo.placename" content="San Francisco" />
