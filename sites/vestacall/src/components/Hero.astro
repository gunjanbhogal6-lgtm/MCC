---
import homeData from "../data/home.json";
import MapVisualization from "./MapVisualization.astro";

const heroData = homeData.hero;
---

<section class="relative overflow-hidden bg-gray-50 pt-24 pb-16">
  <div
    class="absolute top-1/4 -left-64 w-96 h-96 bg-vesta-purple rounded-full mix-blend-multiply filter blur-[150px] opacity-[0.08]"
  >
  </div>
  <div
    class="absolute bottom-1/4 -right-64 w-96 h-96 bg-vesta-purple rounded-full mix-blend-multiply filter blur-[150px] opacity-[0.08]"
  >
  </div>

  <div
    class="container mx-auto px-6 relative z-10 grid grid-cols-1 lg:grid-cols-2 gap-12 items-start"
  >
    <div class="text-left">
      <div
        class="inline-block px-4 py-2 rounded-full bg-vesta-purple/10 border border-vesta-purple/20 text-vesta-purple text-sm font-bold mb-6"
      >
        AI-Powered Cloud Contact Center
      </div>

      <h1
        class="text-4xl md:text-5xl lg:text-[56px] font-extrabold leading-[1.1] mb-5 tracking-tight text-gray-900"
      >
        {heroData.h1}
      </h1>

      <p
        class="text-lg md:text-xl text-gray-700 mb-5 max-w-xl leading-relaxed font-bold border-l-4 border-vesta-purple pl-5"
        itemprop="description"
      >
        {heroData.definition}
      </p>

      <p class="text-base text-gray-500 mb-6 max-w-xl">
        {heroData.subtitle}
      </p>

      <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4">
        <a
          href="/contact"
          class="btn-primary hover:scale-105 transition-transform"
        >
          {heroData.cta1}
        </a>
        <a
          href="/contact"
          class="btn-secondary hover:scale-105 transition-transform"
        >
          {heroData.cta2}
        </a>
      </div>
    </div>

    <div class="relative h-[350px] sm:h-[450px] lg:h-[500px] w-full">
      <MapVisualization />
    </div>
  </div>
</section>

<section class="py-16 bg-white border-t border-gray-100">
  <div class="container mx-auto px-6 max-w-6xl">
    <div class="grid md:grid-cols-3 gap-8">
      {
        heroData.containers.map((container) => (
          <div
            class={`bg-gradient-to-br ${container.color} rounded-2xl p-8 text-white shadow-xl hover:shadow-2xl transform hover:scale-105 transition duration-300 relative overflow-hidden`}
            style={`background: linear-gradient(to bottom right, ${container.color.includes("vesta-purple") ? "#6C2BD9" : container.color.includes("blue") ? "#3b82f6" : "#10b981"}, ${container.color.includes("fuchsia") ? "#c026d3" : container.color.includes("cyan") ? "#06b6d4" : "#0d9488"});`}
          >
            <div class="text-5xl mb-4">
              {container.icon === "brain" && "🧠"}
              {container.icon === "globe" && "🌐"}
              {container.icon === "shield" && "🛡️"}
            </div>

            <h2 class="text-2xl font-bold mb-3">{container.title}</h2>
            <p class="text-white/90 mb-4">{container.description}</p>

            <p class="text-sm text-white/75 italic mb-4 border-l-2 border-white/30 pl-3">
              {container.painPoint}
            </p>

            <div class="flex flex-wrap gap-2">
              {container.keywords.map((keyword) => (
                <span class="inline-block bg-white/20 text-white text-xs font-semibold px-3 py-1 rounded-full">
                  {keyword}
                </span>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
