---
import { Check } from 'lucide-astro';
---

<section class="py-24 bg-[#0b0416] relative overflow-hidden border-t border-vesta-purple/20">
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-vesta-purple/10 rounded-full blur-[150px] pointer-events-none"></div>
  <div class="absolute inset-0 bg-[url('https://grainy-gradients.vercel.app/noise.svg')] opacity-10 mix-blend-overlay"></div>

  <div class="container mx-auto px-6 relative z-10 max-w-7xl">
    <div class="flex flex-col lg:flex-row items-center gap-16">
      <div class="flex-1">
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-vesta-purple/10 border border-vesta-purple/30 text-fuchsia-400 text-sm font-bold mb-6">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5.636 18.364a9 9 0 010-12.728m12.728 0a9 9 0 010 12.728m-9.9-2.829a5 5 0 010-7.07m7.072 0a5 5 0 010 7.07M13 12a1 1 0 11-2 0 1 1 0 012 0z" /></svg>
          The Airlines of Voice Communication
        </div>
        <h2 class="text-4xl md:text-5xl font-black text-white mb-6 leading-tight tracking-tight">
          Unshakable <br />
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-vesta-purple to-fuchsia-500">Network Reliability</span>
        </h2>
        <p class="text-xl text-white/70 mb-8 font-medium leading-relaxed">
          No dropped packets. No jitter. Just crystal-clear, uninterrupted connectivity. Whether you are a global carrier or a growing enterprise, VestaCall provides the backbone for the digital age.
        </p>

        <div class="space-y-6">
          <div class="flex items-start gap-4">
            <div class="mt-1 w-8 h-8 rounded-full bg-white/5 border border-white/10 flex items-center justify-center flex-shrink-0 text-vesta-purple">
              <Check class="w-4 h-4" />
            </div>
            <div>
              <h4 class="text-white font-bold text-lg mb-1">Global Wholesale Routing</h4>
              <p class="text-white/50 font-medium text-sm">Tier-1 connectivity bypassing public congestion.</p>
            </div>
          </div>
          <div class="flex items-start gap-4">
            <div class="mt-1 w-8 h-8 rounded-full bg-white/5 border border-white/10 flex items-center justify-center flex-shrink-0 text-vesta-purple">
              <Check class="w-4 h-4" />
            </div>
            <div>
              <h4 class="text-white font-bold text-lg mb-1">High ASR / Low PDD</h4>
              <p class="text-white/50 font-medium text-sm">Precision engineered for the best connection metrics.</p>
            </div>
          </div>
<div class="flex items-start gap-4">
            <div class="mt-1 w-8 h-8 rounded-full bg-white/5 border border-white/10 flex items-center justify-center flex-shrink-0 text-vesta-purple">
              <Check class="w-4 h-4" />
            </div>
            <div>
              <h4 class="text-white font-bold text-lg mb-1">Carrier-Grade Reliability</h4>
              <p class="text-white/50 font-medium text-sm">99.999% uptime with automatic failover.</p>
            </div>
          </div>
            <div>
              <h4 class="text-white font-bold text-lg mb-1">Redundant Architecture</h4>
              <p class="text-white/50 font-medium text-sm">Instant failover across distributed data centers.</p>
            </div>
          </div>
        </div>
      </div>

      <div class="flex-1 w-full">
        <div class="relative w-full aspect-square md:aspect-[4/3] rounded-3xl bg-white/5 border border-white/10 shadow-2xl p-8 overflow-hidden flex flex-col justify-center items-center">
          <div class="relative w-64 h-64">
            <div class="absolute inset-0 border-2 border-dashed border-vesta-purple/30 rounded-full animate-spin-slow"></div>
            <div class="absolute inset-4 border border-fuchsia-500/20 rounded-full animate-spin-reverse-slow"></div>
            <div class="absolute inset-0 flex items-center justify-center">
              <div class="w-32 h-32 rounded-full bg-gradient-to-br from-vesta-purple to-[#5a24b5] shadow-[0_0_50px_rgba(108,43,217,0.4)] flex items-center justify-center">
                <svg class="w-12 h-12 text-white/90" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
              </div>
            </div>
            <div class="absolute top-10 left-10 w-3 h-3 bg-white rounded-full shadow-[0_0_10px_white] animate-pulse"></div>
            <div class="absolute bottom-12 right-12 w-4 h-4 bg-fuchsia-400 rounded-full shadow-[0_0_15px_#e879f9] animate-pulse" style="animation-delay: 1s"></div>
            <div class="absolute top-1/2 -right-4 w-2 h-2 bg-blue-400 rounded-full shadow-[0_0_10px_#60a5fa] animate-pulse" style="animation-delay: 0.5s"></div>
          </div>
          <div class="absolute inset-0 bg-gradient-to-t from-[#0b0416] via-transparent to-transparent pointer-events-none"></div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes spin-slow {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
  @keyframes spin-reverse-slow {
    from { transform: rotate(360deg); }
    to { transform: rotate(0deg); }
  }
  .animate-spin-slow {
    animation: spin-slow 30s linear infinite;
  }
  .animate-spin-reverse-slow {
    animation: spin-reverse-slow 40s linear infinite;
  }
</style>
