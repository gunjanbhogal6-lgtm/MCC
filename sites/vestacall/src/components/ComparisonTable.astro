---
import homeData from "../data/home.json";

interface ComparisonRow {
  feature: string;
  vestacall: string;
  competitor1: string;
  [key: string]: string;
}

const rows = homeData.comparison.rows as ComparisonRow[];
---

<section class="py-20 bg-gray-50/30" id="comparison">
  <div class="container mx-auto px-6 max-w-7xl">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-5xl font-extrabold text-gray-900 mb-4 tracking-tight">
        {homeData.comparison.title || "VestaCall vs. Competitors"}
      </h2>
      <p class="text-lg text-gray-500 max-w-2xl mx-auto">
        {homeData.comparison.description || "See how our AI-native engineering stacks up against industry leaders."}
      </p>
    </div>

    <div class="bg-white rounded-[2rem] border border-gray-100 shadow-xl overflow-hidden">
      <!-- Desktop Grid -->
      <div class="hidden lg:block">
        <table class="w-full border-collapse" style="table-layout: fixed;">
          <thead>
            <tr class="bg-gray-50/50">
              <th class="text-left py-6 px-8 text-xs uppercase tracking-widest font-black text-gray-600 w-1/3" scope="col">Capabilities</th>
              <th class="py-6 px-8 text-center w-1/3" scope="col">
                <div class="flex flex-col items-center">
                  <span class="text-xl font-black text-gray-900 leading-none">Vesta<span class="text-vesta-purple">Call</span></span>
                  <span class="text-[9px] uppercase tracking-widest font-black text-vesta-purple mt-2">Recommended</span>
                </div>
              </th>
              {homeData.comparison.headers.slice(2).map(header => (
                <th class="py-6 px-8 text-sm font-bold text-gray-600 w-1/3" scope="col">{header}</th>
              ))}
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            {rows.map((row: ComparisonRow) => (
              <tr class="hover:bg-gray-50/30 transition-colors">
                <td class="py-6 px-8 text-sm font-bold text-gray-900">{row.feature}</td>
                
                <!-- VestaCall Highlighted Cell -->
                <td class="py-6 px-8 text-center bg-vesta-purple/[0.02]">
                  <div class="flex items-center justify-center gap-2">
                    <svg class="w-4 h-4 text-vesta-purple" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round">
                      <polyline points="20 6 9 17 4 12"></polyline>
                    </svg>
                    <span class="text-sm font-black text-vesta-purple">{row.vestacall.replace(/✅|⚠️|❌/g, '').trim()}</span>
                  </div>
                </td>

                <td class="py-6 px-8 text-center">
                  {(() => {
                    const val = row.competitor1;
                    const hasWarning = val.includes('⚠️') || val.includes('Limited') || val.includes('Add-on');
                    const hasError = val.includes('❌') || val.includes('Extra');
                    const cleanText = val.replace(/✅|⚠️|❌/g, '').trim();

                    return (
                      <div class="flex items-center justify-center gap-2">
                        {hasWarning && !hasError && (
                          <svg class="w-4 h-4 text-amber-500/60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                        )}
                        {hasError && (
                          <svg class="w-4 h-4 text-rose-400/60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
                        )}
                        <span class="text-sm font-medium text-gray-500">{cleanText}</span>
                      </div>
                    );
                  })()}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <!-- Mobile Layout -->
      <div class="lg:hidden divide-y divide-gray-100">
        {rows.map((row: ComparisonRow) => (
          <div class="p-6">
            <h3 class="text-sm font-black text-gray-900 uppercase tracking-widest mb-4">{row.feature}</h3>
            <div class="space-y-3">
              <div class="flex justify-between items-center bg-vesta-purple/[0.04] p-3 rounded-lg border border-vesta-purple/10">
                <span class="text-xs font-black text-vesta-purple">VestaCall</span>
                <span class="text-xs font-black text-vesta-purple">{row.vestacall.replace(/✅|⚠️|❌/g, '').trim()}</span>
              </div>
              <div class="flex justify-between items-center px-3 text-gray-600">
                <span class="text-xs font-bold uppercase">{homeData.comparison.headers[2] || 'Legacy Providers'}</span>
                <span class="text-xs">{row.competitor1.replace(/✅|⚠️|❌/g, '').trim()}</span>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
