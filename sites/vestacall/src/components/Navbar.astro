---
import navData from "../data/navigation.json";
import {
  ChevronDown,
  Menu,
  X,
  Zap,
  Phone,
  Network,
  MessageSquare,
  Headset,
  BarChart3,
  LifeBuoy,
  Target,
  Globe,
  Building2,
  FileText,
  Lightbulb,
  HelpCircle,
  Users,
  Briefcase,
  Shield,
  Mail,
} from "lucide-astro";

const navbar = navData.navbar;

const iconMap = {
  Phone,
  Network,
  MessageSquare,
  Headset,
  BarChart3,
  LifeBuoy,
  Target,
  Globe,
  Building2,
  FileText,
  Lightbulb,
  HelpCircle,
  Users,
  Briefcase,
  Shield,
  Mail,
  Zap,
};
---

<nav
  class="fixed top-0 left-0 right-0 z-[100] flex justify-center pt-4 px-4"
  id="navbar"
>
  <div
    class="w-full max-w-7xl flex items-center justify-between rounded-full transition-all duration-500 bg-transparent border border-transparent px-6 py-3"
    id="nav-container"
    style="min-height: 60px;"
  >
    <a
      href="/"
      class="flex items-center cursor-pointer shrink-0 group"
      style="align-items: center; height: 100%;"
    >
      <img
        src={navbar.logo.image}
        alt={navbar.logo.text}
        class="h-10 w-auto object-contain bg-transparent"
        style="vertical-align: middle;"
      />
    </a>

    <div class="hidden lg:flex items-center flex-1 justify-center">
      <div class="flex items-center gap-1 relative">
        {
          navbar.menu.map((item) =>
            "dropdown" in item ? (
              <div class="group relative">
                <button class="flex items-center gap-1.5 px-3 lg:px-4 py-2.5 rounded-full text-sm font-bold transition-colors duration-200 text-gray-600 hover:text-gray-900 hover:bg-gray-100/50">
                  {item.label}
                  <ChevronDown class="w-3.5 h-3.5 opacity-60 transition-transform duration-200 group-hover:rotate-180" />
                </button>

                <div class="absolute top-full left-1/2 -translate-x-1/2 pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 pointer-events-none group-hover:pointer-events-auto">
                  <div class="bg-white/95 backdrop-blur-xl border border-gray-200 rounded-3xl p-6 grid grid-cols-2 gap-6 shadow-xl min-w-[500px]">
                    {item.dropdown && Array.isArray(item.dropdown)
                      ? item.dropdown.map((dropdownItem) => {
                          const IconComponent =
                            iconMap[
                              dropdownItem.icon as keyof typeof iconMap
                            ] || Zap;
                          return (
                            <a
                              href={dropdownItem.url}
                              class="flex items-start gap-3 hover:bg-gray-50 p-2.5 -mx-2.5 rounded-2xl transition-all group/item"
                            >
                              <div class="w-10 h-10 rounded-full bg-vesta-purple/5 flex items-center justify-center text-vesta-purple group-hover/item:bg-vesta-purple group-hover/item:text-white transition-colors shrink-0">
                                <IconComponent class="w-4 h-4" />
                              </div>
                              <div class="flex-1">
                                <p class="text-gray-900 font-bold text-sm group-hover/item:text-vesta-purple transition-colors mb-0.5">
                                  {dropdownItem.name}
                                </p>
                                <p class="text-gray-500 font-medium text-xs leading-snug">
                                  {dropdownItem.description}
                                </p>
                              </div>
                            </a>
                          );
                        })
                      : []}
                  </div>
                </div>
              </div>
            ) : (
              <a
                href={item.url}
                class="px-3 lg:px-4 py-2.5 rounded-full text-sm font-bold text-gray-600 hover:text-gray-900 hover:bg-gray-100/50 transition-colors duration-200"
              >
                {item.label}
              </a>
            ),
          )
        }
      </div>
    </div>

    <div class="hidden lg:flex items-center gap-3 shrink-0">
      <a
        href="/login"
        class="px-4 py-2 text-sm font-bold text-gray-900 hover:text-vesta-purple transition-colors"
        >Log In</a
      >
      <a
        href={navbar.cta.primary.url}
        class="px-6 py-2.5 rounded-full bg-vesta-purple text-white text-sm font-bold hover:bg-[#5a24b5] hover:scale-[1.02] active:scale-95 transition-all shadow-md"
      >
        {navbar.cta.primary.text}
      </a>
    </div>

    <button
      class="lg:hidden w-10 h-10 flex items-center justify-center rounded-full bg-gray-100 border border-gray-200 text-gray-900"
      id="mobile-menu-btn"
    >
      <Menu class="w-5 h-5" id="menu-icon" />
      <X class="w-5 h-5 hidden" id="close-icon" />
    </button>
  </div>
</nav>

<div
  class="fixed inset-x-0 top-20 z-[90] p-4 lg:hidden hidden"
  id="mobile-menu"
>
  <div
    class="bg-white border border-gray-200 rounded-3xl p-6 shadow-2xl flex flex-col gap-4 max-h-[75vh] overflow-y-auto"
  >
    {
      navbar.menu.map((item) => (
        <div class="border-b border-gray-100 pb-4 last:border-0 last:pb-0">
          <p class="text-lg font-bold text-gray-900 mb-4">{item.label}</p>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            {"dropdown" in item &&
            item.dropdown &&
            Array.isArray(item.dropdown) ? (
              item.dropdown.map((dropdownItem) => {
                const IconComponent =
                  iconMap[dropdownItem.icon as keyof typeof iconMap] || Zap;
                return (
                  <a
                    href={dropdownItem.url}
                    class="flex items-center gap-3 group"
                  >
                    <div class="w-8 h-8 rounded-full bg-vesta-purple/5 flex items-center justify-center text-vesta-purple group-hover:bg-vesta-purple group-hover:text-white transition-colors shrink-0">
                      <IconComponent class="w-3.5 h-3.5" />
                    </div>
                    <span class="text-sm font-bold text-gray-700 group-hover:text-vesta-purple transition-colors">
                      {dropdownItem.name}
                    </span>
                  </a>
                );
              })
            ) : (
              <a
                href={"url" in item ? item.url : "#"}
                class="text-sm font-bold text-gray-700 hover:text-vesta-purple transition-colors"
              >
                {item.label}
              </a>
            )}
          </div>
        </div>
      ))
    }

    <div class="flex flex-col gap-3 mt-4">
      <a
        href="/login"
        class="w-full text-center py-3 rounded-full bg-gray-50 text-gray-900 font-bold border border-gray-200"
        >Log In</a
      >
      <a
        href={navbar.cta.primary.url}
        class="w-full text-center py-3 rounded-full bg-vesta-purple text-white font-bold shadow-lg"
        >{navbar.cta.primary.text}</a
      >
    </div>
  </div>
</div>

<script is:inline>
  const navContainer = document.getElementById("nav-container");
  const mobileMenuBtn = document.getElementById("mobile-menu-btn");
  const mobileMenu = document.getElementById("mobile-menu");
  const menuIcon = document.getElementById("menu-icon");
  const closeIcon = document.getElementById("close-icon");

  window.addEventListener("scroll", () => {
    if (window.scrollY > 20) {
      navContainer?.classList.remove("bg-transparent", "border-transparent");
      navContainer?.classList.add(
        "bg-white/90",
        "backdrop-blur-2xl",
        "border-gray-200",
        "shadow-lg",
        "shadow-gray-200/50",
        "px-6",
        "py-3",
      );
    } else {
      navContainer?.classList.add("bg-transparent", "border-transparent");
      navContainer?.classList.remove(
        "bg-white/90",
        "backdrop-blur-2xl",
        "border-gray-200",
        "shadow-lg",
        "shadow-gray-200/50",
        "px-6",
        "py-3",
      );
    }
  });

  mobileMenuBtn?.addEventListener("click", () => {
    mobileMenu?.classList.toggle("hidden");
    menuIcon?.classList.toggle("hidden");
    closeIcon?.classList.toggle("hidden");
  });
</script>
