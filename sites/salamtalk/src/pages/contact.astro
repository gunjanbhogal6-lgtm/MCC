---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
---

<Layout
  title="Contact Us"
  description="Contact SalamTalk to request a demo, get support, or learn more about our unified communication platform."
>
  <Navbar />

  <section class="py-24 text-center bg-gradient-to-r from-indigo-50 to-purple-50">
    <h1 class="text-5xl font-bold mb-6">
      Let’s Transform Your Communication
    </h1>
    <p class="text-gray-600 text-lg">
      Our team is ready to help.
    </p>
  </section>

  <Footer />
</Layout>