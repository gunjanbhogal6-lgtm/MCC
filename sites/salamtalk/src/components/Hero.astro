---
import seo from "../data/seo.json";
const heroData = seo.sections.hero;
---

<section class="py-24 bg-gradient-to-r from-indigo-50 to-purple-50">
  <div class="max-w-6xl mx-auto px-6">
    <!-- H1 - Main Hero Title -->
    <div class="text-center mb-16">
      <h1 class="text-5xl md:text-6xl font-bold leading-tight text-gray-900 mb-6">
        {heroData.h1}
      </h1>

      <p class="text-lg md:text-xl text-gray-600 max-w-3xl mx-auto mb-8">
        {heroData.subtitle}
      </p>

      <div class="flex justify-center gap-4 flex-wrap">
        <a href="/contact"
           class="bg-indigo-600 text-white px-8 py-3 rounded-xl shadow-lg hover:scale-105 transition">
          {heroData.cta1}
        </a>

        <a href="/features"
           class="border border-indigo-600 text-indigo-600 px-8 py-3 rounded-xl hover:bg-indigo-600 hover:text-white transition">
          {heroData.cta2}
        </a>
      </div>
    </div>

    <!-- Three Hero Containers with Pain Points -->
    <div class="grid md:grid-cols-3 gap-8">
      {heroData.containers.map((container) => (
        <div class={`bg-gradient-to-br ${container.color} rounded-2xl p-8 text-white shadow-xl hover:shadow-2xl transform hover:scale-105 transition duration-300`}>
          <div class="text-5xl mb-4">{container.icon}</div>
          
          <h3 class="text-2xl font-bold mb-3">
            {container.title}
          </h3>
          
          <p class="text-white text-opacity-90 mb-4">
            {container.description}
          </p>

          <p class="text-sm text-white text-opacity-75 italic mb-4 border-l-2 border-white border-opacity-30 pl-3">
            "{container.painPoint}"
          </p>
          
          <div class="space-y-2">
            {container.keywords.map((keyword) => (
              <span class="inline-block bg-white text-gray-900 text-xs font-semibold px-3 py-1 rounded-full mr-2 mb-2">
                {keyword}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>