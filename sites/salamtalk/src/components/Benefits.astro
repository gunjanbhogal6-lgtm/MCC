---
import seo from "../data/seo.json";
const benefitsData = seo.sections.benefits;
---

<section class="py-24 bg-white text-center">
  <div class="max-w-6xl mx-auto px-6">

    <h2 class="text-4xl md:text-5xl font-bold mb-6 text-gray-900 leading-tight">
      {benefitsData.title}
    </h2>

    <p class="text-lg text-gray-600 max-w-3xl mx-auto mb-16">
      {benefitsData.description}
    </p>

    <!-- Benefits Grid -->
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
      {benefitsData.items.map((item) => (
        <div class="bg-gradient-to-br from-indigo-50 to-purple-50 p-8 rounded-xl hover:shadow-lg transition duration-300 border border-indigo-100">
          <div class="text-4xl mb-4">{item.icon}</div>
          
          <h3 class="text-xl font-bold text-gray-900 mb-3">
            {item.title}
          </h3>
          
          <p class="text-gray-600 text-sm leading-relaxed">
            {item.description}
          </p>
        </div>
      ))}
    </div>

  </div>
</section>