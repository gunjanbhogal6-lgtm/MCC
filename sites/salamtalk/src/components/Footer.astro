---
import seo from "../data/seo.json";
const footerData = seo.sections.footer;
---

<footer class="bg-gray-900 text-gray-100 mt-20">
  <!-- Trust & Certifications -->
  <div class="border-b border-gray-700 py-8 bg-gray-800">
    <div class="max-w-6xl mx-auto px-6 text-center">
      <p class="text-sm text-gray-400 mb-4">
        {footerData.trust}
      </p>
      <div class="flex justify-center gap-4 flex-wrap">
        {footerData.certifications.map((cert) => (
          <span class="text-xs bg-gray-700 px-3 py-1 rounded-full">
            🔒 {cert}
          </span>
        ))}
      </div>
    </div>
  </div>

  <!-- Main Footer -->
  <div class="max-w-6xl mx-auto px-6 py-16 grid md:grid-cols-4 gap-10">

    <!-- Brand -->
    <div>
      <h2 class="text-2xl font-bold text-white mb-4">{footerData.brand.name}</h2>
      <p class="text-gray-400 text-sm">
        {footerData.brand.tagline}
      </p>
    </div>

    <!-- Product -->
    <div>
      <h3 class="font-semibold mb-4 text-white">Product</h3>
      <ul class="space-y-2 text-gray-400 text-sm">
        {footerData.sections.product.map((item) => (
          <li>
            <a href={item.url} class="hover:text-indigo-400 transition">
              {item.name}
            </a>
            <span class="text-xs text-gray-600 ml-2">({item.keywords})</span>
          </li>
        ))}
      </ul>
    </div>

    <!-- Company -->
    <div>
      <h3 class="font-semibold mb-4 text-white">Company</h3>
      <ul class="space-y-2 text-gray-400 text-sm">
        {footerData.sections.company.map((item) => (
          <li>
            <a href={item.url} class="hover:text-indigo-400 transition">
              {item.name}
            </a>
            <span class="text-xs text-gray-600 ml-2">({item.keywords})</span>
          </li>
        ))}
      </ul>
    </div>

    <!-- Contact Info -->
    <div>
      <h3 class="font-semibold mb-4 text-white">Get in Touch</h3>
      <ul class="space-y-2 text-gray-400 text-sm">
        <li>Email: <a href={`mailto:${footerData.sections.contact.email}`} class="text-indigo-400 hover:underline">{footerData.sections.contact.email}</a></li>
        <li>Phone: <a href={`tel:${footerData.sections.contact.phone}`} class="text-indigo-400 hover:underline">{footerData.sections.contact.phone}</a></li>
        <li>{footerData.sections.contact.hours}</li>
      </ul>
    </div>

  </div>

  <!-- Copyright -->
  <div class="border-t border-gray-700 py-6 text-center text-gray-500 text-sm">
    <p>© {new Date().getFullYear()} {footerData.brand.name}. All rights reserved. | <a href="#" class="hover:text-gray-400">Privacy Policy</a> | <a href="#" class="hover:text-gray-400">Terms of Service</a></p>
  </div>
</footer>