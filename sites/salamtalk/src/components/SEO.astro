---
import seo from "../data/seo.json";

const { pathname = "/", title: propTitle, description: propDescription } = Astro.props;

const title = propTitle || seo.seo.metaTitle;
const description = propDescription || seo.seo.metaDescription;

const allKeywords = [
  ...seo.keywords.primary,
  ...seo.keywords.secondary
].join(", ");

const canonicalURL = `${seo.site.url}${pathname}`;
---

<title>{title}</title>

<meta name="description" content={description} />
<meta name="keywords" content={allKeywords} />
<meta name="author" content={seo.site.author} />
<meta name="robots" content="index, follow" />
<link rel="canonical" href={canonicalURL} />

<!-- Open Graph -->
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={`${seo.site.url}${seo.site.defaultImage}`} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:type" content="website" />
<meta property="og:site_name" content={seo.site.name} />

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:site" content={seo.site.twitterHandle} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={`${seo.site.url}${seo.site.defaultImage}`} />

<!-- Structured Data -->
<script
  type="application/ld+json"
  set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    name: seo.site.name,
    applicationCategory: "BusinessApplication",
    description: description,
    keywords: allKeywords,
    url: seo.site.url,
    offers: {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "USD",
      "description": "Free trial available"
    }
  })}
/>
