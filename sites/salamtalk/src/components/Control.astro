---
import seo from "../data/seo.json";
const controlData = seo.sections.h2_control;
---

<section class="py-24 bg-white">
  <div class="max-w-6xl mx-auto px-6">
    <!-- H2 Title with Scaling Confidence -->
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">
        {controlData.title}
      </h2>
      <p class="text-xl text-gray-600 max-w-2xl mx-auto">
        {controlData.description}
      </p>
    </div>

    <!-- H3 Grid -->
    <div class="grid md:grid-cols-2 gap-8">
      {controlData.h3_items.map((item) => (
        <div class="border border-gray-200 rounded-xl p-8 hover:border-indigo-300 hover:shadow-lg transition">
          <h3 class="text-2xl font-bold text-gray-900 mb-3">
            {item.heading}
          </h3>
          <p class="text-gray-600 leading-relaxed">
            {item.content}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
