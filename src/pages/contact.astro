---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact Us | My Call Connect" description="Get in touch with My Call Connect. Our team is ready to help you with your business communication needs.">
  <section class="hero">
    <div class="container">
      <div class="hero-ring ring-1 hide-on-mobile"></div>
      <div class="hero-ring ring-2 hide-on-mobile"></div>
      
      <div class="hero-content animate-up">
        <span class="badge">Get in Touch</span>
        <h1>We're Here to <br><span class="text-gradient">Help You Connect</span></h1>
        <p class="delay-1 animate-up">Have questions about our products, pricing, or need technical support? Reach out to our team today.</p>
      </div>
    </div>
  </section>

  <section class="section" id="contact-form">
    <div class="container">
      <div class="grid-2 gap-12">
        <!-- Contact Info -->
        <div>
          <div class="section-header text-left">
            <h2>Let's Start a <span class="text-gradient-primary">Conversation</span></h2>
            <p>Fill out the form or use our contact details below. We typically respond within 2 hours during business hours.</p>
          </div>
          
          <div class="space-y-8 mt-8">
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-primary/10 rounded-full flex items-center justify-center text-primary shrink-0">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
              </div>
              <div>
                <h3 class="text-xl font-bold mb-1">Sales & Support</h3>
                <p class="text-gray-500 mb-2">Speak directly with our team.</p>
                <a href="tel:+15550123" class="text-primary font-semibold hover:underline">+1 (555) 012-3456</a>
              </div>
            </div>
            
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-primary/10 rounded-full flex items-center justify-center text-primary shrink-0">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
              </div>
              <div>
                <h3 class="text-xl font-bold mb-1">Email Us</h3>
                <p class="text-gray-500 mb-2">For general inquiries and support.</p>
                <a href="mailto:hello@mycallconnect.com" class="text-primary font-semibold hover:underline">hello@mycallconnect.com</a>
              </div>
            </div>
            
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-primary/10 rounded-full flex items-center justify-center text-primary shrink-0">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
              </div>
              <div>
                <h3 class="text-xl font-bold mb-1">Headquarters</h3>
                <p class="text-gray-500">123 Innovation Drive<br>San Francisco, CA 94103</p>
              </div>
            </div>
          </div>
        </div>
        
        <!-- Contact Form -->
        <div class="bg-surface border border-white/10 rounded-2xl p-8 shadow-lg">
          <form class="space-y-6">
            <div class="grid-2 gap-6">
              <div>
                <label for="first-name" class="block text-sm font-semibold mb-2">First Name</label>
                <input type="text" id="first-name" class="w-full px-4 py-3 rounded-lg bg-background border border-white/10 focus:border-primary outline-none transition-colors" placeholder="John" required>
              </div>
              <div>
                <label for="last-name" class="block text-sm font-semibold mb-2">Last Name</label>
                <input type="text" id="last-name" class="w-full px-4 py-3 rounded-lg bg-background border border-white/10 focus:border-primary outline-none transition-colors" placeholder="Doe" required>
              </div>
            </div>
            
            <div>
              <label for="email" class="block text-sm font-semibold mb-2">Work Email</label>
              <input type="email" id="email" class="w-full px-4 py-3 rounded-lg bg-background border border-white/10 focus:border-primary outline-none transition-colors" placeholder="john@company.com" required>
            </div>
            
            <div>
              <label for="message" class="block text-sm font-semibold mb-2">Message</label>
              <textarea id="message" rows="4" class="w-full px-4 py-3 rounded-lg bg-background border border-white/10 focus:border-primary outline-none transition-colors" placeholder="How can we help you?" required></textarea>
            </div>
            
            <button type="submit" class="btn btn-primary w-full justify-center">Send Message</button>
            <p class="text-xs text-center text-gray-500">By sending this form, you agree to our <a href="#" class="text-primary hover:underline">Privacy Policy</a>.</p>
          </form>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container container-sm text-center">
      <div class="section-header">
        <h2>Global <span class="text-gradient-primary">Presence</span></h2>
        <p>We serve customers in over 100 countries worldwide.</p>
      </div>
      <div class="relative mt-12">
        <img src="https://upload.wikimedia.org/wikipedia/commons/8/80/World_map_-_low_resolution.svg" alt="World Map" class="w-full opacity-20 invert">
        <!-- Add decorative dots if needed -->
      </div>
    </div>
  </section>
</Layout>
