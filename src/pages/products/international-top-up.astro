---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="International Mobile Top-Up | Global Airtime API - My Call Connect" description="Send mobile top-ups instantly to over 500 networks worldwide. Secure, fast, and reliable airtime transfer solutions for businesses.">
  <section class="hero">
    <div class="container">
      <div class="hero-ring ring-1 hide-on-mobile"></div>
      <div class="hero-ring ring-2 hide-on-mobile"></div>
      
      <div class="hero-content animate-up">
        <span class="badge">Global Rewards</span>
        <h1>International <br><span class="text-gradient">Mobile Top-Up</span></h1>
        <p class="delay-1 animate-up">Instantly recharge mobile phones worldwide. The perfect solution for rewards programs, remittances, and employee incentives.</p>
        <div class="hero-cta delay-2 animate-up">
          <a href="/contact" class="btn btn-primary">Connect API <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg></a>
          <a href="#networks" class="text-link">View Networks</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section" id="features">
    <div class="container">
      <div class="section-header">
        <h2>Global <span class="text-gradient-primary">Airtime Network</span></h2>
        <p>Connect to the world's largest mobile recharge ecosystem.</p>
      </div>
      <div class="grid-3">
        <!-- Extensive Reach -->
        <div class="card card-hover-effect">
          <div class="card-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><line x1="2" y1="12" x2="22" y2="12"></line><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path></svg>
          </div>
          <h3>Extensive Reach</h3>
          <p>Access to 500+ mobile operators across 160+ countries.</p>
          <ul class="mt-4 space-y-2 text-gray-500 mb-6 list-none">
            <li class="flex items-center gap-2"><svg class="w-4 h-4 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg> Emerging Markets</li>
            <li class="flex items-center gap-2"><svg class="w-4 h-4 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg> Major Carriers</li>
            <li class="flex items-center gap-2"><svg class="w-4 h-4 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg> Data Bundles</li>
          </ul>
        </div>

        <!-- Real-Time API -->
        <div class="card card-hover-effect">
          <div class="card-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"></path></svg>
          </div>
          <h3>Real-Time Processing</h3>
          <p>Transactions are processed instantly, ensuring immediate delivery to the end-user.</p>
          <ul class="mt-4 space-y-2 text-gray-500 mb-6 list-none">
            <li class="flex items-center gap-2"><svg class="w-4 h-4 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg> &lt; 3s Latency</li>
            <li class="flex items-center gap-2"><svg class="w-4 h-4 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg> 99.9% Uptime</li>
            <li class="flex items-center gap-2"><svg class="w-4 h-4 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg> Instant Confirmation</li>
          </ul>
        </div>

        <!-- Secure & Scalable -->
        <div class="card card-hover-effect">
          <div class="card-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
          </div>
          <h3>Secure & Scalable</h3>
          <p>Bank-grade security protocols to protect every transaction.</p>
          <ul class="mt-4 space-y-2 text-gray-500 mb-6 list-none">
            <li class="flex items-center gap-2"><svg class="w-4 h-4 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg> Fraud Detection</li>
            <li class="flex items-center gap-2"><svg class="w-4 h-4 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg> Balance Protection</li>
            <li class="flex items-center gap-2"><svg class="w-4 h-4 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg> Auto-Scaling</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <div class="grid-2">
        <div class="content-image">
          <div class="content-icon">
            <svg width="60" height="60" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5"><path d="M12 2v20"></path><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path></svg>
          </div>
          <h3>Multi-Currency Support</h3>
          <p>Handle transactions in any currency with auto-conversion.</p>
        </div>
        <div>
          <h2 class="section-title">Ideal for <span class="text-gradient-primary">Modern Businesses</span></h2>
          <p class="section-desc">Integrate mobile top-ups into your existing products to increase engagement and revenue.</p>
          
          <div class="feature-list mt-8">
            <div class="feature-item">
              <div class="feature-item-num">01</div>
              <div>
                <h3>Fintech & Wallets</h3>
                <p>Allow users to recharge their phones directly from your banking or wallet app.</p>
              </div>
            </div>
            <div class="feature-item">
              <div class="feature-item-num">02</div>
              <div>
                <h3>Rewards Programs</h3>
                <p>Incentivize user behavior with instant airtime rewards instead of points.</p>
              </div>
            </div>
            <div class="feature-item">
              <div class="feature-item-num">03</div>
              <div>
                <h3>E-Commerce</h3>
                <p>Cross-sell top-ups at checkout to increase average order value.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container container-sm">
      <div class="cta-box">
        <div class="cta-content">
          <span class="badge badge-light">Expand Your Reach</span>
          <h2>Integrate Airtime Top-Up Today</h2>
          <p>Get access to our comprehensive API documentation and start testing in our sandbox.</p>
          <div class="flex justify-center gap-4 mt-8">
            <a href="/contact" class="btn btn-light">Contact Sales</a>
            <a href="#" class="btn btn-outline-white">API Docs</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
