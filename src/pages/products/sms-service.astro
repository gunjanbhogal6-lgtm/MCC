---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Bulk SMS Service | A2P Messaging API - My Call Connect" description="Reliable Bulk SMS and A2P messaging platform. Reach customers globally with high delivery rates for OTPs, alerts, and marketing campaigns.">
  <section class="hero">
    <div class="container">
      <div class="hero-ring ring-1 hide-on-mobile"></div>
      <div class="hero-ring ring-2 hide-on-mobile"></div>
      
      <div class="hero-content animate-up">
        <span class="badge">Instant Delivery</span>
        <h1>Bulk SMS & <br><span class="text-gradient">A2P Messaging</span></h1>
        <p class="delay-1 animate-up">Engage your audience with the industry's most reliable SMS platform. Perfect for marketing, notifications, and two-factor authentication.</p>
        <div class="hero-cta delay-2 animate-up">
          <a href="/contact" class="btn btn-primary">Start Messaging <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg></a>
          <a href="#use-cases" class="text-link">View Use Cases</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section" id="features">
    <div class="container">
      <div class="section-header">
        <h2>Powerful <span class="text-gradient-primary">Messaging Features</span></h2>
        <p>Everything you need to run successful SMS campaigns at scale.</p>
      </div>
      <div class="grid-3">
        <!-- High Throughput -->
        <div class="card card-hover-effect">
          <div class="card-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"></path></svg>
          </div>
          <h3>High Throughput</h3>
          <p>Send millions of messages per hour with our robust infrastructure designed for speed.</p>
          <ul class="mt-4 space-y-2 text-gray-500 mb-6 list-none">
            <li class="flex items-center gap-2"><svg class="w-4 h-4 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg> 500+ TPS</li>
            <li class="flex items-center gap-2"><svg class="w-4 h-4 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg> Low Latency</li>
            <li class="flex items-center gap-2"><svg class="w-4 h-4 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg> Instant Delivery</li>
          </ul>
        </div>

        <!-- Global Reach -->
        <div class="card card-hover-effect">
          <div class="card-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><path d="M2 12h20"></path><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path></svg>
          </div>
          <h3>Global Coverage</h3>
          <p>Reach customers on any network, anywhere in the world. Direct connections to 800+ operators.</p>
          <ul class="mt-4 space-y-2 text-gray-500 mb-6 list-none">
            <li class="flex items-center gap-2"><svg class="w-4 h-4 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg> 200+ Countries</li>
            <li class="flex items-center gap-2"><svg class="w-4 h-4 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg> Unicode Support</li>
            <li class="flex items-center gap-2"><svg class="w-4 h-4 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg> Long SMS Concatenation</li>
          </ul>
        </div>

        <!-- API Integration -->
        <div class="card card-hover-effect">
          <div class="card-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="16 18 22 12 16 6"></polyline><polyline points="8 6 2 12 8 18"></polyline></svg>
          </div>
          <h3>Developer API</h3>
          <p>Integrate SMS capabilities into your software in minutes with our developer-friendly REST API.</p>
          <ul class="mt-4 space-y-2 text-gray-500 mb-6 list-none">
            <li class="flex items-center gap-2"><svg class="w-4 h-4 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg> SMPP & HTTP</li>
            <li class="flex items-center gap-2"><svg class="w-4 h-4 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg> Delivery Reports (DLR)</li>
            <li class="flex items-center gap-2"><svg class="w-4 h-4 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg> 24/7 Dev Support</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-alt" id="use-cases">
    <div class="container">
      <div class="grid-2">
        <div>
          <h2 class="section-title">Built for Critical <span class="text-gradient-primary">Communication</span></h2>
          <p class="section-desc">Whether you're securing accounts or driving sales, our SMS platform delivers the reliability your business needs.</p>
          
          <div class="feature-list mt-8">
            <div class="feature-item">
              <div class="feature-item-num">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
              </div>
              <div>
                <h3>2FA & OTP</h3>
                <p>Secure user accounts with time-sensitive one-time passwords delivered instantly.</p>
              </div>
            </div>
            <div class="feature-item">
              <div class="feature-item-num">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path><path d="M13.73 21a2 2 0 0 1-3.46 0"></path></svg>
              </div>
              <div>
                <h3>Transactional Alerts</h3>
                <p>Keep customers informed with order updates, appointment reminders, and service notifications.</p>
              </div>
            </div>
            <div class="feature-item">
              <div class="feature-item-num">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21.21 15.89A10 10 0 1 1 8 2.83"></path><path d="M22 12A10 10 0 0 0 12 2v10z"></path></svg>
              </div>
              <div>
                <h3>Marketing Campaigns</h3>
                <p>Drive engagement and sales with personalized promotional messages and offers.</p>
              </div>
            </div>
          </div>
        </div>
        <div class="content-image">
          <div class="content-icon">
            <svg width="60" height="60" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
          </div>
          <h3>Smart Routing</h3>
          <p>Our AI automatically selects the best path for optimal delivery rates.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container container-sm">
      <div class="cta-box">
        <div class="cta-content">
          <span class="badge badge-light">Get Started</span>
          <h2>Start Sending in Minutes</h2>
          <p>Sign up for a developer account and get free test credits to try our API.</p>
          <div class="flex justify-center gap-4 mt-8">
            <a href="/contact" class="btn btn-light">Contact Sales</a>
            <a href="#" class="btn btn-outline-white">API Docs</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
