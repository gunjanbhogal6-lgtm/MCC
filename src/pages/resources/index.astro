        </div>
      </div>
      
      <div class="grid-3">
        <!-- Most Popular -->
        <div class="card card-hover-effect">
          <span class="badge badge-sm mb-4">Most Popular</span>
          <div class="text-sm font-bold text-primary mb-2">Guide</div>
          <h3>Complete Guide to AI-Powered Communications</h3>
          <p class="mb-4">Learn how to leverage AI features to transform your business communications</p>
          <div class="flex items-center text-sm text-gray-500 gap-2">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
            15 min read
          </div>
        </div>
        
        <!-- New -->
        <div class="card card-hover-effect">
          <span class="badge badge-sm mb-4">New</span>
          <div class="text-sm font-bold text-primary mb-2">Video</div>
          <h3>Getting Started with My Call Connect in 10 Minutes</h3>
          <p class="mb-4">Quick video walkthrough for new users to get up and running fast</p>
          <div class="flex items-center text-sm text-gray-500 gap-2">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
            10 min watch
          </div>
        </div>
        
        <!-- Featured -->
        <div class="card card-hover-effect">
          <span class="badge badge-sm mb-4">Featured</span>
          <div class="text-sm font-bold text-primary mb-2">Case Study</div>
          <h3>How TechCorp Increased Productivity by 40%</h3>
          <p class="mb-4">Real-world success story of enterprise transformation</p>
