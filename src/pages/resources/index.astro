        <div class="card card-hover-effect">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 bg-green-100 text-green-600 rounded-full flex items-center justify-center font-bold">G</div>
            <div>
              <h4 class="font-bold text-sm">Global Healthcare</h4>
              <p class="text-xs text-gray-500">Healthcare</p>
            </div>
          </div>
          <div class="text-2xl font-bold text-primary mb-2">60%</div>
