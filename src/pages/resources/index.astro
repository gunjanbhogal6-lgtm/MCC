  <section class="section" aria-labelledby="newsletter-heading">
    <div class="container container-sm">
      <div class="newsletter-box">
        <div class="relative z-10">
          <span class="newsletter-pill">Stay Updated</span>
          
          <h2 id="newsletter-heading" class="newsletter-heading">
            Subscribe to our<br/>newsletter
          </h2>
          
          <p class="newsletter-sub">
            Get the latest resources, tips, and product updates delivered straight to your inbox.
          </p>
          
          <form class="newsletter-input-container" action="#" method="POST" aria-label="Newsletter Subscription Form">
            <div class="newsletter-label-container">
              
              <div class="newsletter-input-wrapper">
                <span class="newsletter-icon">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
                </span>
                <input 
                  id="newsletter-email" 
                  type="email" 
                  name="email" 
                  placeholder="Enter your email address" 
                  required 
                  class="newsletter-input" 
                />
              </div>
            </div>
            
            <button type="submit" class="newsletter-btn">
              <span>Subscribe</span>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"></path></svg>
            </button>
          </form>
          
          <p class="newsletter-footer">
            Join 25,000+ subscribers. Unsubscribe at any time.
          </p>
        </div>
      </div>
    </div>
  </section>

