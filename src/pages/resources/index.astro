        <!-- Security -->
        <div class="card card-hover-effect">
          <div class="text-sm font-bold text-primary mb-2">Security</div>
          <h3>Enterprise Security & Compliance Guide</h3>
          <p class="mb-4">Understanding our security features</p>
          <div class="text-sm text-gray-500">15 min</div>
        </div>
        <!-- Admin -->
        <div class="card card-hover-effect">
          <div class="text-sm font-bold text-primary mb-2">Admin</div>
          <h3>Admin Panel: Complete Guide</h3>
          <p class="mb-4">Manage users, billing, and settings</p>
          <div class="text-sm text-gray-500">20 min</div>
        </div>
      </div>
    </div>
  </section>

