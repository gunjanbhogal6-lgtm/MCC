---
import Layout from '../../layouts/Layout.astro';
import LogoSlider from '../../components/LogoSlider.astro';
---

<Layout title="Resource Center | My Call Connect" description="Explore My Call Connect's resource center for guides, tutorials, case studies, and more to help you succeed.">
<section class="hero">
    <div class="container">
      <div class="hero-ring ring-1 hide-on-mobile"></div>
      <div class="hero-ring ring-2 hide-on-mobile"></div>
      
      <div class="hero-content animate-up">
        <span class="badge">Resource Center</span>
        <h1>Learn, Grow & Succeed with <br><span class="text-gradient">My Call Connect</span></h1>
        <p class="delay-1 animate-up">Explore our comprehensive library of guides, tutorials, case studies, and more to get the most out of your communication platform.</p>
        
        <div class="search-container delay-2 animate-up">
          <div class="search-bar">
            <svg class="search-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
            <input type="text" placeholder="Search resources, guides, tutorials...">
            <button class="btn-search">Search</button>
          </div>
        </div>
      </div>
    </div>
  </section>

  <LogoSlider />

  <section class="section">
    <div class="container">
      <div class="grid-3">
        <!-- API Docs -->
        <div class="card card-hover-effect">
          <div class="card-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="16 18 22 12 16 6"></polyline><polyline points="8 6 2 12 8 18"></polyline></svg></div>
          <h3>API Docs</h3>
          <p>Documentation</p>
        </div>
        <!-- Blog -->
        <div class="card card-hover-effect">
          <div class="card-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg></div>
          <h3>Blog</h3>
          <p>200+ articles</p>
        </div>
        <!-- Guides & Tutorials -->
        <div class="card card-hover-effect">
          <div class="card-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="16" x2="12" y2="12"></line><line x1="12" y1="8" x2="12.01" y2="8"></line></svg></div>
          <h3>Guides & Tutorials</h3>
          <p>120+ resources</p>
        </div>
        <!-- Videos & Webinars -->
        <div class="card card-hover-effect">
          <div class="card-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg></div>
          <h3>Videos & Webinars</h3>
          <p>85+ resources</p>
        </div>
        <!-- Case Studies -->
        <div class="card card-hover-effect">
          <div class="card-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg></div>
          <h3>Case Studies</h3>
          <p>45+ resources</p>
        </div>
        <!-- Whitepapers -->
        <div class="card card-hover-effect">
          <div class="card-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="12" y1="18" x2="12" y2="12"></line><line x1="9" y1="15" x2="15" y2="15"></line></svg></div>
          <h3>Whitepapers</h3>
          <p>30+ resources</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <div class="section-header">
        <h2>Featured <span class="text-gradient-primary">Resources</span></h2>
        <p>Hand-picked content to help you succeed</p>
        <div class="mt-4">
