            <div>
              <h4 class="font-bold text-sm">EduTech Solutions</h4>
              <p class="text-xs text-gray-500">Education</p>
            </div>
          </div>
          <div class="text-2xl font-bold text-primary mb-2">300%</div>
          <p class="font-bold mb-2">User Growth</p>
          <p class="text-sm text-gray-500 mb-4">Scaling educational platform with reliable communications</p>
          <a href="#" class="text-link pl-0 text-sm">Read Full Story</a>
        </div>
      </div>
    </div>
